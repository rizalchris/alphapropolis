---
import {
	Facebook,
	Instagram,
	Mail,
	Phone,
	Smartphone,
	Youtube,
} from "lucide-astro";
const contacts = [
	{ Icon: Smartphone, label: "0811-8130-1000", href: "tel:+628118131000" },
	{ Icon: Phone, label: "021-4586 7977", href: "tel:+622145867977" },
	{
		Icon: Mail,
		label: "info@alphapropolis.id",
		href: "mailto:info@alphapropolis.id",
	},
];
const socials = [
	{
		Icon: Instagram,
		label: "@official_alphapropolis",
		href: "https://www.instagram.com/alphapropolis_/",
	},
	{
		Icon: Youtube,
		label: "@alphapropolis",
		href: "https://www.youtube.com/@alphapropolis",
	},
	{
		Icon: Facebook,
		label: "Alpha Propolis",
		href: "https://www.facebook.com/alphapropolis",
	},
];
---

<footer id="wa-footer" class="w-full">
	<img
		class="block w-full lg:hidden"
		src="/images/footer-mobile.webp"
		alt="Footer Alpha Propolis"
		width="430"
		height="467"
		loading="lazy"
		decoding="async"
	/>

	<div
		class="mx-auto hidden w-full gap-10 bg-slate-900 px-6 py-16 sm:px-8 lg:grid lg:grid-cols-[1.4fr_1fr_1fr] lg:px-24 lg:py-24"
	>
		<section
			class="flex w-full flex-col items-start justify-start gap-5"
			aria-labelledby="wa-footer-brand"
		>
			<h2 id="wa-footer-brand" class="sr-only">Alpha Propolis</h2>
			<img
				src="/images/footer.webp"
				alt="Footer Alpha Propolis"
				width="1440"
				height="1200"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</section>

		<address
			class="flex min-w-0 flex-col items-start justify-start gap-2.5 not-italic"
			aria-labelledby="wa-footer-contact"
		>
			<h2
				id="wa-footer-contact"
				class="self-stretch text-xs font-bold uppercase leading-4 tracking-wide text-white"
			>
				Kontak
			</h2>
			<ul class="flex w-full flex-col gap-2.5">
				{
					contacts.map(({ Icon, label, href }) => (
						<li class="inline-flex w-full items-start justify-start gap-2.5">
							<Icon
								class="mt-1 size-3.5 shrink-0 text-amber-400"
								aria-hidden="true"
							/>
							{href ? (
								<a
									href={href}
									class="flex-1 text-xs font-normal leading-5 text-neutral-200 hover:text-white"
								>
									{label}
								</a>
							) : (
								<span class="flex-1 text-xs font-normal leading-5 text-neutral-200">
									{label}
								</span>
							)}
						</li>
					))
				}
			</ul>
		</address>

		<section
			class="flex min-w-0 flex-col items-start justify-start gap-2.5"
			aria-labelledby="wa-footer-social"
		>
			<h2
				id="wa-footer-social"
				class="self-stretch text-xs font-bold uppercase leading-4 tracking-wide text-white"
			>
				Dapatkan Info Kesehatan Gratis
			</h2>
			<ul class="flex w-full flex-col gap-2.5">
				{
					socials.map(({ Icon, label, href }) => (
						<li class="inline-flex w-full items-center justify-start gap-2.5">
							<Icon
								class="size-3.5 text-amber-400"
								aria-hidden="true"
							/>
							<a
								href={href}
								target="_blank"
								rel="noopener noreferrer"
								class="text-xs font-normal leading-5 text-neutral-200 hover:text-white"
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
			<p class="self-stretch text-xs font-bold text-slate-100">
				Info update promo, tips diabetes, dan konten kesehatan harian.
			</p>
		</section>
	</div>
</footer>
