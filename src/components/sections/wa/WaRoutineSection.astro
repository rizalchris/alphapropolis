---
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section id="wa-routine" aria-label="Cara Paling Praktis Melindungi Tubuh Anda" class="mx-auto w-full overflow-hidden bg-stone-100 px-6 py-16 sm:px-8 lg:px-10 lg:py-32">
	<div class="mx-auto w-full max-w-[var(--container-xl)]">
		<img
			src="/images/Cara-Paling-Praktis-Melindungi-Tubuh-Anda-mobile.webp"
			alt="Cara Paling Praktis Melindungi Tubuh Anda"
			width="720"
			height="960"
			loading="lazy"
			decoding="async"
			class="h-auto w-full md:hidden"
		/>

		<img
			src="/images/Cara-Paling-Praktis-Melindungi-Tubuh-Anda.webp"
			alt="Cara Paling Praktis Melindungi Tubuh Anda"
			width="1440"
			height="1200"
			loading="lazy"
			decoding="async"
			class="hidden h-auto w-full md:block"
		/>

		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Mulai Ikhtiar"
			class="mx-auto mt-6 block w-full max-w-[380px]"
		>
			<img
				src="/images/btn-mulai-ikhtiar.webp"
				alt="Mulai Ikhtiar"
				width="720"
				height="160"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</a>
	</div>
</section>
