---
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section
	id="wa-routine"
	aria-label="Cara Paling Praktis Melindungi Tubuh Anda"
	class="mx-auto w-full overflow-hidden px-6 py-16 sm:px-8 lg:px-10 lg:py-32 bg-[#fcf7f0]"
>
	<div class="mx-auto w-full max-w-[var(--container-xl)]">
		<picture class="block w-full">
			<source
				media="(min-width: 768px)"
				srcset="/images/Cara-Paling-Praktis-Melindungi-Tubuh-Anda.webp"
			/>
			<img
				src="/images/Cara-Paling-Praktis-Melindungi-Tubuh-Anda-mobile.webp"
				alt="Cara Paling Praktis Melindungi Tubuh Anda"
				width="720"
				height="960"
				loading="lazy"
				decoding="async"
				class="h-auto w-full object-contain md:aspect-[6/5]"
			/>
		</picture>

		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Mulai Ikhtiar"
			class="mx-auto mt-6 block w-full max-w-[380px]"
		>
			<img
				src="/images/btn-mulai-ikhtiar.webp"
				alt="Mulai Ikhtiar"
				width="720"
				height="160"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</a>
	</div>
</section>
