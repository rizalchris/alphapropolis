---
import { ArrowRight, Check, MessageCircle } from "lucide-astro";
import { whatsappOrderUrl } from "../../../lib/site";

const badges = ["BPOM TR-213656281", "HALAL MUI", "CPOTB", "ISO 9001:2015"];
const assurances = [
	"Jaminan Keamanan Belanja 100% Tanpa Risiko",
	"Garansi 100% Keaslian Produk",
	"Garansi ganti baru jika rusak saat pengiriman",
];
---

<section
	id="wa-final-cta"
	aria-labelledby="wa-final-cta-title"
	class="mx-auto w-full px-6 py-16 sm:px-8 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[1200px] flex-col items-center justify-start gap-10 rounded-3xl bg-gradient-to-br from-orange-50 to-stone-50 px-6 py-11 text-center outline outline-1 outline-offset-[-1px] outline-amber-400/30 sm:px-12 lg:gap-12"
	>
		<h2
			id="wa-final-cta-title"
			class="max-w-[658px] text-center font-bold leading-tight text-gray-900 lg:leading-[57.60px]"
		>
			Jangan Tunggu Sampai Terlambat Mulai Dari Hari Ini
		</h2>
		<ul
			class="flex flex-col items-center justify-start gap-5 lg:flex-row lg:flex-wrap lg:justify-center"
		>
			{
				assurances.map((item) => (
					<li class="inline-flex items-center justify-center gap-2.5">
						<Check
							class="size-7 text-green-500"
							aria-hidden="true"
						/>
						<span class="text-lg font-bold leading-6 text-neutral-800 sm:text-2xl">
							{item}
						</span>
					</li>
				))
			}
		</ul>
		<ul class="flex flex-wrap items-center justify-center gap-1.5">
			{
				badges.map((badge) => (
					<li class="inline-flex min-h-7 flex-col items-start justify-start rounded-full bg-amber-100 px-3.5 py-[5px] shadow-[0px_1px_6px_0px_rgba(0,0,0,0.06)] outline outline-1 outline-offset-[-1px] outline-amber-400">
						<div class="text-xs font-bold leading-4 text-stone-900">
							✓ {badge}
						</div>
					</li>
				))
			}
		</ul>
		<div class="flex flex-col items-center justify-start gap-2.5">
			<a
				href={whatsappOrderUrl}
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Pesan Alpha Propolis melalui WhatsApp sekarang"
				class="inline-flex w-full min-h-16 max-w-full items-center justify-center gap-2.5 rounded-full bg-gradient-to-br from-green-500 to-green-600 px-5 py-5 shadow-[0px_6px_20px_0px_rgba(34,197,94,0.30)] sm:w-auto sm:px-12"
			>
				<MessageCircle class="size-4 text-white" aria-hidden="true" />
				<span
					class="text-center text-[15px] font-bold leading-7 text-white sm:text-lg"
					>Klaim Promo</span
				>
				<ArrowRight class="size-4 text-white" aria-hidden="true" />
			</a>
			<div
				class="text-center text-base font-normal leading-5 text-gray-700"
			>
				Garansi 30 Hari · Gratis Ongkir · Respons &lt; 5 menit
			</div>
		</div>
	</div>
</section>
