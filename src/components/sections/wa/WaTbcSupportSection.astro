---
import { whatsappOrderUrl } from "../../../lib/site";
---

<section
	id="wa-tbc"
	aria-label="Pemulihan TBC dengan Alpha Propolis"
	class="mx-auto flex w-full flex-col items-center justify-start gap-14 px-6 py-16 sm:px-8 lg:px-10 lg:py-24"
>
	<div class="w-full max-w-[920px] md:hidden">
		<img
			src="/images/Pemulihan-TBC-mobile.webp"
			alt="Pemulihan TBC dengan Alpha Propolis"
			width="720"
			height="960"
			loading="lazy"
			decoding="async"
			class="h-auto w-full"
		/>
	</div>

	<div
		class="hidden w-full max-w-[920px] flex-col items-center justify-start gap-12 md:flex"
	>
		<img
			src="/images/Pemulihan-TBC.webp"
			alt="Pendamping alami terbaik untuk mempercepat pemulihan TBC"
			width="1440"
			height="1200"
			loading="lazy"
			decoding="async"
			class="block h-auto w-full"
		/>
		<a
			href={whatsappOrderUrl}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Chat WhatsApp untuk konsultasi efek samping pengobatan"
			class="block w-full max-w-[380px]"
		>
			<img
				src="/images/btn-lawan-efek-samping.webp"
				alt="Lawan Efek Samping"
				width="720"
				height="160"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</a>
	</div>
</section>
