---
import { ArrowRight, MessageCircle } from "lucide-astro";
import { whatsappOrderUrl } from "../../../lib/site";
---

<section
	id="wa-tbc"
	aria-labelledby="wa-tbc-title"
	class="mx-auto flex w-full flex-col items-center justify-start gap-14 px-6 py-16 sm:px-8 lg:px-10 lg:py-24"
>
	<div class="w-full max-w-[920px] md:hidden">
		<img
			src="/images/Pemulihan-TBC-mobile.webp"
			alt="Pemulihan TBC dengan Alpha Propolis"
			width="720"
			height="960"
			loading="lazy"
			decoding="async"
			class="h-auto w-full"
		/>
	</div>

	<div
		class="hidden w-full max-w-[920px] flex-col items-center justify-start gap-12 md:flex"
	>
		<img
			src="/images/Pemulihan-TBC.webp"
			alt="Pendamping alami terbaik untuk mempercepat pemulihan TBC"
			width="1440"
			height="1200"
			loading="lazy"
			decoding="async"
			class="block h-auto w-full"
		/>
		<a
			href={whatsappOrderUrl}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Chat WhatsApp untuk konsultasi efek samping pengobatan"
			class="inline-flex w-full min-h-16 max-w-full items-center justify-center gap-2.5 rounded-none bg-gradient-to-br from-green-500 to-green-600 px-5 py-5 shadow-[0px_6px_20px_0px_rgba(34,197,94,0.30)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-105 sm:w-auto sm:px-12"
		>
			<MessageCircle class="size-4 text-white" aria-hidden="true" />
			<span
				class="text-center text-[18px] font-bold leading-7 text-white sm:text-lg"
				>Lawan Efek Samping</span
			>
			<ArrowRight class="size-4 text-white" aria-hidden="true" />
		</a>
	</div>
</section>
