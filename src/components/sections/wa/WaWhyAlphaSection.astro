---
import { Sparkles } from "lucide-astro";
---

<section
	id="wa-why-alpha"
	aria-labelledby="wa-why-alpha-title"
	class="mx-auto w-full overflow-hidden px-6 py-16 sm:px-8 lg:px-10 lg:py-24"
>
	<div
		class="mx-auto flex w-full max-w-[1044px] flex-col items-center justify-start gap-5"
	>
		<div
			class="inline-flex h-8 items-center justify-start gap-1.5 rounded-none bg-orange-50 px-4 py-1.5 outline outline-1 outline-offset-[-1px] outline-amber-400/30"
		>
			<Sparkles class="size-2.5 text-amber-400" aria-hidden="true" />
			<div
				class="text-center text-xs font-bold uppercase leading-4 tracking-wide text-amber-400"
			>
				Mengapa Alpha Propolis?
			</div>
		</div>
		<h2
			id="wa-why-alpha-title"
			class="self-stretch text-center font-bold leading-tight text-gray-900 lg:leading-[57.60px]"
		>
			Propolis Biasa vs Alpha Propolis
		</h2>
		<picture class="block w-full">
			<source
				media="(min-width: 1024px)"
				srcset="/images/alphapropolis-vs-propolis-biasa-2.webp"
			/>
			<img
				class="h-auto w-full max-w-[515px] object-contain lg:max-w-none"
				src="/images/mobile-alphapropolis-vs-propolis.webp"
				alt="Perbandingan Alpha Propolis dan propolis biasa"
				width="515"
				height="544"
				loading="lazy"
				decoding="async"
			/>
		</picture>
	</div>
</section>
