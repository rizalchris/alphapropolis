---
import { Sparkles } from "lucide-astro";

const benefits = [
	{
		title: ["Kadar Fenol", "1.600 mg/L"],
		body: "1.6x lebih banyak antioksidan aktif yang masuk ke tubuh Anda",
		image: "/images/Kadar-Fenol.webp",
	},
	{
		title: ["IC50", "1-50ppm"],
		body: "IC50 (1-50ppm): Kaya antioksidan dan mudah diserap tubuh.",
		image: "/images/IC50.webp",
	},
	{
		title: ["Lebah Trigona 67% + Lebah Apis Mellifera 33%"],
		body: "Perlindungan ganda untuk menjaga imun dan mempercepat pemulihan Anda.",
		image: "/images/Lebah_Trigona_+_Lebah_Apis_Mellifera.webp",
	},
	{
		title: ["Flavonoid dan Asam Fenolat"],
		body: "Merawat sensitivitas insulin tubuh, memastikan energi Anda tetap terjaga sepanjang hari.",
		image: "/images/Flavonoid%20dan%20Asam%20Fenolat.webp",
	},
];
---

<section
	id="wa-why-alpha"
	aria-labelledby="wa-why-alpha-title"
	class="mx-auto w-full overflow-hidden px-6 py-20 sm:px-8 lg:px-10 lg:py-24"
>
	<div
		class="mx-auto flex w-full max-w-[1044px] flex-col items-center justify-start gap-5"
	>
		<div
			class="inline-flex h-8 items-center justify-start gap-1.5 rounded-full bg-orange-50 px-4 py-1.5 outline outline-1 outline-offset-[-1px] outline-amber-400/30"
		>
			<Sparkles class="size-2.5 text-amber-400" aria-hidden="true" />
			<div
				class="text-center text-xs font-bold uppercase leading-4 tracking-wide text-amber-400"
			>
				Mengapa Alpha Propolis?
			</div>
		</div>
		<h2
			id="wa-why-alpha-title"
			class="self-stretch text-center text-3xl font-bold leading-tight text-gray-900 sm:text-4xl lg:text-5xl lg:leading-[57.60px]"
		>
			Propolis Biasa vs Alpha Propolis
		</h2>
		<img
			class="h-auto w-full max-w-[515px] object-contain"
			src="/images/botol-alphapropolis.webp"
			alt="Propolis biasa vs Alpha Propolis"
			width="515"
			height="544"
			loading="lazy"
			decoding="async"
		/>

		<ul class="grid w-full gap-5 sm:grid-cols-2 lg:grid-cols-4">
			{
				benefits.map((benefit) => (
					<li class="h-full">
					<article class="flex h-full w-full flex-col items-center justify-start gap-2.5 rounded-3xl bg-white px-5 py-9 shadow-[0px_4px_20px_0px_rgba(0,0,0,0.07)] outline outline-1 outline-offset-[-1px] outline-amber-100">
						<div class="relative aspect-[216/162] w-full max-w-52 overflow-hidden rounded-[10px] bg-stone-50">
							<img
								class="absolute inset-0 h-full w-full object-cover object-center"
								src={benefit.image}
								alt=""
								width="216"
								height="162"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="self-stretch text-center text-xl font-bold leading-7 text-neutral-800 sm:text-2xl">
							{benefit.title.map((line, index) => (
								<>
									{index > 0 && <br />}
									{line}
								</>
							))}
						</div>
						<div class="self-stretch text-center text-base font-normal leading-6 text-gray-900 sm:text-lg">
							{benefit.body}
						</div>
					</article>
					</li>
				))
			}
		</ul>
	</div>
</section>
