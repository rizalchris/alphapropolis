---
import { ArrowRight, Check, MessageCircle, Sparkles } from "lucide-astro";
import { whatsappOrderUrl } from "../../../lib/site";

const symptoms = [
	"Sering haus",
	"Sering buang air kecil",
	"Mudah lapar",
	"Cepat lelah",
	"Berat badan turun tanpa sebab",
];
---

<section
	id="wa-problem"
	aria-labelledby="wa-problem-title"
	class="mx-auto w-full overflow-hidden px-6 py-16 text-center sm:px-8 lg:px-10 lg:py-24"
>
	<div class="mx-auto flex w-full max-w-[1440px] flex-col items-center gap-5">
		<div
			class="inline-flex h-8 items-center justify-start gap-1.5 rounded-none bg-orange-50 px-4 py-1.5 outline outline-1 outline-offset-[-1px] outline-amber-400/30"
		>
			<Sparkles class="size-2.5 text-amber-400" aria-hidden="true" />
			<div
				class="text-xs font-bold uppercase leading-4 tracking-wide text-amber-400"
			>
				Apakah Ini Terjadi Pada Anda?
			</div>
		</div>

		<h2
			id="wa-problem-title"
			class="max-w-[878px] font-bold leading-tight text-neutral-800 lg:leading-[48px]"
		>
			Jangan Tunggu Tubuh Memberi Tanda
		</h2>

		<strong class="max-w-3xl text-lg leading-8 sm:text-xl sm:leading-9">
			Organ Bisa Rusak Sebelum Kamu Sadar Waspadai Sebelum Terlambat
		</strong>

		<ul
			class="mx-auto flex w-full max-w-lg flex-col items-start justify-start gap-2.5 pb-7 text-left"
		>
			{
				symptoms.map((symptom) => (
					<li class="inline-flex items-start justify-start gap-3">
						<span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-none bg-amber-200">
							<Check
								class="size-3 text-amber-400"
								aria-hidden="true"
							/>
						</span>
						<strong class="text-base leading-6 text-stone-900 sm:text-xl">
							{symptom}
						</strong>
					</li>
				))
			}
		</ul>

		<h3
			class="max-w-[650px] text-2xl font-bold leading-8 text-gray-900 sm:text-3xl sm:leading-9"
		>
			Jika sinyal terus dibiarkan, ini ancaman komplikasi yang bisa
			terjadi
		</h3>

		<div
			class="w-[calc(100%+3rem)] -mx-6 overflow-hidden rounded-none sm:mx-0 sm:w-full sm:max-w-[1200px] sm:rounded-none"
		>
			<picture
				class="block h-full w-full flex items-center justify-center mb-8"
			>
				<img
					src="/images/anatomi-2.webp"
					alt="Ilustrasi ancaman komplikasi diabetes jika tanda awal terus dibiarkan"
					width="400"
					height="400"
					loading="lazy"
					decoding="async"
					class="h-auto rounded-none object-cover"
				/>
			</picture>
		</div>

		<picture class="block w-full">
			<source media="(min-width: 1024px)" srcset="/images/Foto-Akibat.webp" />
			<img
				src="/images/akibat-diabetes.webp"
				alt="Akibat diabetes"
				width="430"
				height="932"
				loading="lazy"
				decoding="async"
				class="aspect-[215/466] h-auto w-full object-contain lg:aspect-[8/5]"
			/>
		</picture>

		<a
			href={whatsappOrderUrl}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Buktikan sendiri manfaat Alpha Propolis melalui WhatsApp"
			class="inline-flex w-full min-h-16 max-w-full items-center justify-center gap-2.5 rounded-none bg-gradient-to-br from-green-500 to-green-600 px-5 py-5 shadow-[0px_6px_20px_0px_rgba(34,197,94,0.30)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-105 sm:w-auto sm:px-12"
		>
			<MessageCircle class="size-4 text-white" aria-hidden="true" />
			<span
				class="text-center text-[18px] font-bold leading-7 text-white sm:text-lg"
				>Buktikan Sendiri</span
			>
			<ArrowRight class="size-4 text-white" aria-hidden="true" />
		</a>
	</div>
</section>
