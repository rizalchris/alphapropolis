---
---

<section id="wa-hero" aria-label="WhatsApp Hero Alpha Propolis" class="mx-auto w-full overflow-hidden">
	<div class="mx-auto w-full max-w-[1200px]">
		<picture class="block w-full">
			<source media="(min-width: 768px)" srcset="/images/wa-hero.webp" />
			<img
				src="/images/wa-mobile-hero.webp"
				alt="WhatsApp Hero Alpha Propolis"
				width="720"
				height="960"
				loading="eager"
				decoding="async"
				fetchpriority="high"
				class="h-auto w-full object-contain md:aspect-[6/5]"
			/>
		</picture>

		<figure class="w-full">
			<img
				src="/images/Foto%20Artis.webp"
				alt="Foto artis bersama Alpha Propolis"
				width="480"
				height="592"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</figure>
	</div>
</section>
