---
import { ArrowRight, MessageCircle, Sparkles } from "lucide-astro";
import { whatsappOrderUrl } from "../../../lib/site";

const badges = ["BPOM TR-213656281", "HALAL MUI", "CPOTB", "ISO 9001:2015"];
const highlights = [
	"1600 mg/L Phenol",
	"67% Lebah Trigona",
	"IC50 Rendah",
	"BPOM RI · HALAL MUI · CPTOB · ISO",
];
---

<section
	id="wa-hero"
	aria-labelledby="wa-hero-title"
	class="mx-auto w-full overflow-hidden"
>
	<ul
		class="flex w-full flex-wrap items-center justify-center gap-x-10 gap-y-2 bg-stone-950 px-5 py-2.5 text-center"
	>
		{
			highlights.map((item) => (
				<li class="text-base font-bold uppercase leading-4 tracking-wide text-white/90">
					{item}
				</li>
			))
		}
	</ul>

	<div
		class="mx-auto flex w-full max-w-[1200px] flex-col items-center justify-center gap-14 px-6 pb-0 pt-16 text-center sm:px-8 sm:pb-0 sm:pt-16 lg:pb-0 lg:pt-28"
	>
		<div class="flex w-full flex-col items-center justify-start gap-8">
			<div
				class="inline-flex min-h-8 items-center justify-center gap-1.5 rounded-none bg-orange-50 px-4 py-1.5 outline outline-1 outline-offset-[-1px] outline-amber-400/30"
			>
				<Sparkles class="size-2.5 text-amber-400" aria-hidden="true" />
				<div
					class="text-xs font-bold uppercase leading-4 tracking-wide text-amber-400"
				>
					Formula Premium Lebah Trigona
				</div>
			</div>

			<h1
				id="wa-hero-title"
				class="text-4xl font-bold leading-tight text-gray-900 sm:text-5xl lg:text-6xl lg:leading-[64px]"
			>
				Sebelum Komplikasi Diabetes Datang, Lindungi Tubuh Anda
				Sekarang!
			</h1>

			<ul class="flex flex-wrap items-center justify-center gap-1.5">
				{
					badges.map((badge) => (
						<li class="inline-flex min-h-7 flex-col items-start justify-start rounded-none bg-amber-100 px-3.5 py-[5px] shadow-[0px_1px_6px_0px_rgba(0,0,0,0.06)] outline outline-1 outline-offset-[-1px] outline-amber-400">
							<div class="text-xs font-bold leading-4 text-stone-900">
								✓ {badge}
							</div>
						</li>
					))
				}
			</ul>

			<div class="flex flex-col items-center justify-start gap-2">
				<a
					href={whatsappOrderUrl}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Chat WhatsApp untuk pesan Alpha Propolis sekarang"
					class="inline-flex w-full min-h-16 max-w-full items-center justify-center gap-2.5 rounded-none bg-gradient-to-br from-green-500 to-green-600 px-5 py-5 shadow-[0px_6px_20px_0px_rgba(34,197,94,0.30)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-105 sm:w-auto sm:px-12"
				>
					<MessageCircle
						class="size-4 text-white"
						aria-hidden="true"
					/>
					<span
						class="text-center text-[18px] font-bold leading-7 text-white sm:text-lg"
						>Lindungi Saya Sekarang</span
					>
					<ArrowRight class="size-4 text-white" aria-hidden="true" />
				</a>
				<div class="text-base font-normal leading-5 text-zinc-800">
					Respons &lt; 5 menit · Konsultasi gratis · Pengiriman hari
					ini
				</div>
			</div>
		</div>

		<figure class="w-full overflow-hidden">
			<img
				class="h-full w-full object-cover"
				src="/images/Foto%20Artis.webp"
				alt="Foto artis bersama Alpha Propolis"
				width="480"
				height="592"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
		</figure>
	</div>
</section>
