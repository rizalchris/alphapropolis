---
const contactItems = [
	{ label: "Telepon", value: "+62 812-3456-7890", href: "tel:+6281234567890" },
	{ label: "Email", value: "info@alphapropolis.id", href: "mailto:info@alphapropolis.id" },
	{ label: "Lokasi", value: "Jakarta, Indonesia" },
];

const socialItems = [
	{ label: "Instagram", value: "@alphapropolis.id" },
	{ label: "YouTube", value: "Alpha Propolis Official" },
	{ label: "TikTok", value: "Alpha Propolis Indonesia" },
];
---

<footer
	id="site-footer"
	aria-labelledby="footer-brand"
	class="landing-section border-t border-[var(--color-footer-border)] bg-[var(--color-footer)] px-6 pt-16 pb-8 sm:px-8 lg:px-10"
>
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col gap-12">
		<div class="grid gap-10 lg:grid-cols-[1.2fr_0.9fr_0.9fr]">
			<div>
				<div class="flex items-center gap-3">
					<div class="flex h-10 w-10 items-center justify-center rounded-[20px] bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-dark)] text-xs font-extrabold text-white">
						AP
					</div>
					<p id="footer-brand" class="text-lg font-extrabold text-white">Alpha Propolis</p>
				</div>
				<p class="mt-4 max-w-md text-sm text-[var(--color-dark-muted)]">
					Suplemen kesehatan premium dari lebah Trigona &amp; Apis Mellifera.
					Membantu ribuan penderita diabetes hidup lebih sehat.
				</p>
				<p class="mt-4 text-xs tracking-wide text-[var(--color-footer-muted)]">
					BPOM RI NA18230411097
				</p>
			</div>

			<div>
				<h2 class="text-xs font-bold uppercase tracking-[0.16em] text-white">
					Kontak
				</h2>
				<address class="not-italic">
					<ul class="mt-5 flex flex-col gap-3">
						{
							contactItems.map((item) => (
								<li>
									<p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--color-primary-dark)]">
										{item.label}
									</p>
									{
										item.href ? (
											<a
												href={item.href}
												class="mt-1 block text-sm text-[var(--color-dark-muted)] transition-colors hover:text-white"
											>
												{item.value}
											</a>
										) : (
											<p class="mt-1 text-sm text-[var(--color-dark-muted)]">
												{item.value}
											</p>
										)
									}
								</li>
							))
						}
					</ul>
				</address>
			</div>

			<div>
				<h2 class="text-xs font-bold uppercase tracking-[0.16em] text-white">
					Ikuti Kami
				</h2>
				<ul class="mt-5 flex flex-col gap-3">
					{
						socialItems.map((item) => (
							<li>
								<p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--color-primary-dark)]">
									{item.label}
								</p>
								<p class="mt-1 text-sm text-[var(--color-dark-muted)]">
									{item.value}
								</p>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div class="h-px w-full bg-[var(--color-footer-border)]"></div>

		<div class="flex flex-col gap-3 text-xs text-[var(--color-footer-muted)] lg:flex-row lg:items-center lg:justify-between">
			<p>© 2026 Alpha Propolis. Hak cipta dilindungi.</p>
			<p>Produk ini bukan obat. Tidak untuk mendiagnosis atau mengobati penyakit.</p>
		</div>
	</div>
</footer>
