---
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section id="final-cta" aria-labelledby="final-cta-title" class="landing-section px-6 py-16 sm:px-8 sm:py-24 lg:px-10">
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center">
		<h2 id="final-cta-title" class="sr-only">Sudah terbukti aman dan dipercaya ribuan orang</h2>
		<img
			src="/images/sudah-terbukti.webp"
			alt="Sudah terbukti aman dan dipercaya ribuan orang"
			width="1200"
			height="1200"
			loading="lazy"
			decoding="async"
			class="h-auto w-full max-w-[1200px]"
		/>
		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Sekarang Giliran Anda"
			class="mt-6 block w-full max-w-[380px]"
		>
			<img
				src="/images/btn-sekarang-giliran-anda.webp"
				alt="Sekarang Giliran Anda"
				width="720"
				height="160"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</a>
	</div>
</section>
