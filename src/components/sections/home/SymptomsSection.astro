---
import SectionLabel from "../../shared/SectionLabel.astro";

const symptoms = [
	{
		image: "/images/Gejala%20Diabetes-01%20.webp",
		title: "Sering buang air kecil",
	},
	{ image: "/images/Gejala%20Diabetes-02%20.webp", title: "Mudah Haus" },
	{ image: "/images/Gejala%20Diabetes-03%20.webp", title: "Mudah Lapar" },
	{
		image: "/images/Gejala%20Diabetes-04%20.webp",
		title: "Berat badan turun drastis",
	},
	{
		image: "/images/Gejala%20Diabetes-05%20.webp",
		title: "Kelelahan ekstrim (Lemas)",
	},
];
---

<section
	id="symptoms"
	aria-labelledby="symptoms-title"
	class="landing-section bg-white px-6 py-16 sm:px-8 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-5"
	>
		<div class="flex max-w-3xl flex-col items-center gap-5 text-center">
			<SectionLabel text="Apakah Ini Terjadi Pada Anda?" />
			<h2 id="symptoms-title" class="text-neutral-800">
				Kenali Sinyal Tubuh Anda
			</h2>
		</div>

		<div class="relative w-full pt-5">
			<ul
				class="grid w-full gap-5 sm:grid-cols-2 lg:grid-cols-5"
			>
				{
					symptoms.map(({ image, title }) => (
						<li>
							<div class="flex h-full flex-col items-center justify-center gap-5 rounded-none border border-amber-100 bg-white p-10 text-center shadow-card-md">
								<div class="flex h-40 w-40 items-center justify-center overflow-hidden bg-orange-50">
									<img
										src={image}
										alt={title}
										width="170"
										height="170"
										loading="lazy"
										decoding="async"
										class="h-full w-full object-cover"
									/>
								</div>
								<h3 class="max-w-40 text-xl font-bold leading-6 text-neutral-800">
									{title}
								</h3>
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
