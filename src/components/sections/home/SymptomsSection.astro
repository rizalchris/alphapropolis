---
import SectionLabel from "../../shared/SectionLabel.astro";
---

<section
	id="symptoms"
	aria-labelledby="symptoms-title"
	class="landing-section bg-white px-6 py-16 sm:px-8 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-5"
	>
		<div
			class="flex max-w-3xl flex-col items-center gap-5 text-center md:hidden"
		>
			<SectionLabel text="Apakah Ini Terjadi Pada Anda?" />
			<h2 id="symptoms-title" class="text-neutral-800">
				Kenali Sinyal Tubuh Anda
			</h2>
		</div>

		<picture class="block w-full">
			<source
				media="(min-width: 768px)"
				srcset="/images/Horizontal-Waspada-Diabetes.webp"
			/>
			<img
				src="/images/Vertical-Waspada-Diabetes.webp"
				alt="Waspada diabetes"
				width="720"
				height="960"
				loading="lazy"
				decoding="async"
				class="h-auto w-full object-contain md:aspect-[8/5]"
			/>
		</picture>
	</div>
</section>
