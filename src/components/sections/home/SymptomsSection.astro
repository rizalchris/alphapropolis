---
import SectionLabel from "../../shared/SectionLabel.astro";
---

<section
	id="symptoms"
	aria-labelledby="symptoms-title"
	class="landing-section bg-white px-6 py-16 sm:px-8 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-5"
	>
		<div class="flex max-w-3xl flex-col items-center gap-5 text-center md:hidden">
			<SectionLabel text="Apakah Ini Terjadi Pada Anda?" />
			<h2 id="symptoms-title" class="text-neutral-800">
				Kenali Sinyal Tubuh Anda
			</h2>
		</div>

		<div class="w-full md:hidden">
			<img
				src="/images/Waspada%20Diabetes-mobile.webp"
				alt="Waspada diabetes"
				width="720"
				height="960"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</div>

		<img
			src="/images/kenali-sinyal.webp"
			alt="Kenali sinyal tubuh Anda"
			width="1440"
			height="900"
			loading="lazy"
			decoding="async"
			class="hidden h-auto w-full md:block"
		/>
	</div>
</section>
