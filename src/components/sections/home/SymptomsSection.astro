---
import SectionLabel from "../../shared/SectionLabel.astro";

const symptoms = [
	{
		image: "/images/Sering%20buang%20air%20kecil.webp",
		title: "Sering buang air kecil",
	},
	{ image: "/images/Mudah%20Haus.webp", title: "Mudah Haus" },
	{ image: "/images/%C2%A0Mudah%20Lapar.webp", title: "Mudah Lapar" },
	{
		image: "/images/Berat%20badan%20turun%20drastis.webp",
		title: "Berat badan turun drastis",
	},
	{
		image: "/images/Kelelahan%20ekstrim%20(Lemas).webp",
		title: "Kelelahan ekstrim (Lemas)",
	},
];
---

<section
	id="symptoms"
	aria-labelledby="symptoms-title"
	class="landing-section bg-white px-6 py-24 sm:px-8 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-5"
	>
		<div class="flex max-w-3xl flex-col items-center gap-5 text-center">
			<SectionLabel text="Apakah Ini Terjadi Pada Anda?" />
			<h2 id="symptoms-title" class="text-neutral-800">
				Kenali Sinyal Tubuh Anda
			</h2>
		</div>

		<div class="relative w-full pt-5">
			<div class="mb-4 flex items-center justify-end gap-3 sm:hidden">
				<button
					type="button"
					class="flex size-11 items-center justify-center rounded-full border border-stone-200 bg-white text-stone-900 shadow-[0px_4px_20px_0px_rgba(0,0,0,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-40"
					data-symptoms-prev
					aria-label="Gejala sebelumnya"
				>
					<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-5">
						<path
							d="M15 18l-6-6 6-6"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</button>
				<button
					type="button"
					class="flex size-11 items-center justify-center rounded-full border border-stone-200 bg-white text-stone-900 shadow-[0px_4px_20px_0px_rgba(0,0,0,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:brightness-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-40"
					data-symptoms-next
					aria-label="Gejala berikutnya"
				>
					<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-5">
						<path
							d="M9 18l6-6-6-6"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</button>
			</div>
			<ul
				class="flex w-full snap-x snap-mandatory gap-5 overflow-x-auto pb-2 sm:grid sm:grid-cols-2 sm:overflow-visible lg:grid-cols-5"
				data-symptoms-track
			>
				{
					symptoms.map(({ image, title }) => (
						<li class="w-[82vw] max-w-[320px] shrink-0 snap-start sm:w-full sm:max-w-none">
							<div class="flex h-full flex-col items-center justify-center gap-5 rounded-3xl border border-amber-100 bg-white p-10 text-center shadow-card-md">
								<div class="flex h-40 w-40 items-center justify-center overflow-hidden bg-orange-50">
									<img
										src={image}
										alt={title}
										width="170"
										height="170"
										loading="lazy"
										decoding="async"
										class="h-full w-full object-cover"
									/>
								</div>
								<h3 class="max-w-40 text-xl font-bold leading-6 text-neutral-800">
									{title}
								</h3>
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		const symptomsSection = document.getElementById("symptoms");
		const track = symptomsSection?.querySelector("[data-symptoms-track]");
		const prevButton = symptomsSection?.querySelector("[data-symptoms-prev]");
		const nextButton = symptomsSection?.querySelector("[data-symptoms-next]");

		if (
			track instanceof HTMLElement &&
			prevButton instanceof HTMLButtonElement &&
			nextButton instanceof HTMLButtonElement
		) {
			const updateButtons = () => {
				const maxScrollLeft = track.scrollWidth - track.clientWidth;
				prevButton.disabled = track.scrollLeft <= 4;
				nextButton.disabled = track.scrollLeft >= maxScrollLeft - 4;
			};

			const scrollAmount = () => {
				const firstItem = track.querySelector("li");
				return firstItem instanceof HTMLElement
					? firstItem.getBoundingClientRect().width + 20
					: 320;
			};

			prevButton.addEventListener("click", () => {
				track.scrollBy({ left: -scrollAmount(), behavior: "smooth" });
			});

			nextButton.addEventListener("click", () => {
				track.scrollBy({ left: scrollAmount(), behavior: "smooth" });
			});

			track.addEventListener("scroll", updateButtons, { passive: true });
			window.addEventListener("resize", updateButtons);
			updateButtons();
		}
	})();
</script>
