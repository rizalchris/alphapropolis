---
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section id="pricing" aria-label="Pricing Alpha Propolis" class="landing-section bg-white px-6 py-16 sm:px-8 lg:px-10">
	<div class="mx-auto w-full max-w-[var(--container-xl)]">
		<img
			src="/images/pricing-mobile.webp"
			alt="Pricing Alpha Propolis"
			width="720"
			height="960"
			loading="lazy"
			decoding="async"
			class="block h-auto w-full md:hidden"
		/>

		<img
			src="/images/pricing.webp"
			alt="Pricing Alpha Propolis"
			width="1440"
			height="1200"
			loading="lazy"
			decoding="async"
			class="hidden h-auto w-full md:block"
		/>

		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Klaim Khusus Hari Ini"
			class="mx-auto mt-6 block w-full max-w-[380px]"
		>
			<img
				src="/images/btn-klaim-khusus-hari-ini.webp"
				alt="Klaim Khusus Hari Ini"
				width="720"
				height="160"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</a>
	</div>
</section>
