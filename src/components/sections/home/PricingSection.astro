---
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section
	id="pricing"
	aria-label="Pricing Alpha Propolis"
	class="landing-section px-6 py-16 sm:px-8 lg:px-10 bg-[#f8f5ec]"
>
	<div class="mx-auto w-full max-w-[var(--container-xl)]">
		<picture class="block w-full">
			<source media="(min-width: 768px)" srcset="/images/pricing.webp" />
			<img
				src="/images/pricing-mobile.webp"
				alt="Pricing Alpha Propolis"
				width="720"
				height="960"
				loading="lazy"
				decoding="async"
				class="h-auto w-full object-contain md:aspect-[6/5]"
			/>
		</picture>

		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Klaim Khusus Hari Ini"
			class="mx-auto mt-6 block w-full max-w-[380px]"
		>
			<img
				src="/images/btn-klaim-khusus-hari-ini.webp"
				alt="Klaim Khusus Hari Ini"
				width="720"
				height="160"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</a>
	</div>
</section>
