---
import {
	BadgeCheck,
	BanknoteArrowDown,
	Handshake,
	MapPinned,
	ShieldCheck,
	Truck,
} from "lucide-astro";
import SectionLabel from "../../shared/SectionLabel.astro";

const benefits = [
	{
		icon: Handshake,
		text: "Menjadi Pelanggan PRIORITAS untuk Mendapatkan Pelayanan yang ISTIMEWA.",
	},
	{
		icon: ShieldCheck,
		text: "100% Produk Dijamin ORI",
	},
	{
		icon: MapPinned,
		text: "GRATIS ONGKIR hingga 100% ke SELURUH INDONESIA",
	},
	{
		icon: BanknoteArrowDown,
		text: "DIJAMIN LEBIH MURAH",
	},
	{
		icon: BadgeCheck,
		text: "GRATIS PENDAMPINGAN DAN KONSULTASI EKSKLUSIF",
	},
	{
		icon: Truck,
		text: "BISA COD HARI INI. Bisa COD bayar saat barang sampai!.",
	},
];
---

<section
	id="direct-benefits"
	aria-labelledby="direct-benefits-title"
	class="landing-section bg-white px-6 py-16 sm:px-8 lg:px-10"
>
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-8">
		<div class="flex max-w-4xl flex-col items-center gap-5 text-center">
			<SectionLabel text="Belanja Langsung" />
			<h2 id="direct-benefits-title" class="text-gray-900">
				Keuntungan Belanja Langsung di Sini
			</h2>
		</div>

		<div class="w-full max-w-6xl border border-amber-400/30 bg-gradient-to-br from-orange-50 to-stone-50 px-6 py-8 shadow-card-md sm:px-8 sm:py-10 lg:px-12">
			<ol class="grid gap-4 lg:grid-cols-2">
				{
					benefits.map(({ icon: Icon, text }, index) => (
						<li class="flex h-full items-start gap-4 border border-amber-100 bg-white px-4 py-4 shadow-card-md sm:px-5">
							<div class="flex size-12 shrink-0 items-center justify-center bg-amber-100 text-amber-600">
								<Icon class="size-5" aria-hidden="true" />
							</div>
							<div class="flex flex-col gap-2">
								<p class="text-xs font-bold uppercase tracking-[0.16em] text-amber-500">
									Benefit {String(index + 1).padStart(2, "0")}
								</p>
								<p class="text-lg font-bold leading-7 text-stone-900">
									{text}
								</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</div>
</section>
