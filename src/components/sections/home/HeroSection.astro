---
import { ArrowRight, MessageCircle } from "lucide-astro";
import SectionLabel from "../../shared/SectionLabel.astro";
import CertificationChips from "../../shared/CertificationChips.astro";
import Button from "../../ui/Button.astro";
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section
	id="hero"
	aria-labelledby="hero-title"
	class="landing-section relative overflow-hidden bg-[linear-gradient(60deg,#f5f5f4_0%,#ffedd5_50%,#f5f5f4_100%)]"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col gap-14 px-6 pb-0 pt-36 sm:px-8 sm:pb-0 sm:pt-36 lg:px-10 lg:pb-0 lg:pt-40"
	>
		<div class="flex flex-col items-center gap-14">
			<div class="flex flex-col items-start gap-8">
				<div class="w-full md:hidden">
					<img
						src="/images/banner-home-mobile.webp"
						alt="Banner Alpha Propolis"
						width="720"
						height="420"
						loading="eager"
						decoding="async"
						fetchpriority="high"
						class="h-auto w-full"
					/>
				</div>

				<div class="hidden md:block">
					<SectionLabel text="Formula Premium Lebah Trigona" />
				</div>

				<img
					src="/images/banner-home.webp"
					alt="Banner home Alpha Propolis"
					width="720"
					height="420"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class="hidden h-auto w-full md:block"
				/>

				<div class="hidden md:block">
					<CertificationChips />
				</div>

				<div class="flex w-full max-w-md flex-col items-start gap-4">
					<Button
						href={whatsappHref}
						size="lg"
						class="h-16 w-full"
						target="_blank"
						rel="noopener noreferrer"
					>
						<MessageCircle class="h-4 w-4" aria-hidden="true" />
						<span>Cegah Komplikasi Sekarang</span>
						<ArrowRight class="h-4 w-4" aria-hidden="true" />
					</Button>
					<strong class="text-base fw-800 leading-5 text-zinc-800">
						Respons &lt; 5 menit · Konsultasi gratis · Pengiriman
						hari ini
					</strong>
				</div>
			</div>

			<figure class="hidden overflow-hidden md:block">
				<img
					src="/images/Foto%20Artis.webp"
					alt="Foto artis bersama Alpha Propolis"
					width="480"
					height="592"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class="h-full w-full object-cover"
				/>
			</figure>
		</div>
	</div>
</section>
