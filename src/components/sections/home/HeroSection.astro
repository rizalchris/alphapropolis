---
const ctaHref =
	"https://alphapropolis.gass.my.id/cta?p=01139F92CD8E6AA37994A49D71738DB6&divisi=lead&msg=Promo+ID+%5B_gid_%5D+%25break%25%25break%25Hallo+Mbak+Alpha%2C+Saya+mau+tanaya-tanya+untuk+produk+Alpha+Propolisnya+dong!+%25break%25%25break%25*Mohon+tidak+menghapus+Promo+ID&cta=1&v=2";
---

<section
	id="hero"
	aria-labelledby="hero-title"
	class="landing-section relative overflow-hidden bg-[linear-gradient(60deg,#f5f5f4_0%,#ffedd5_50%,#f5f5f4_100%)]"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col gap-14 px-6 pb-0 pt-36 sm:px-8 sm:pb-0 sm:pt-36 lg:px-10 lg:pb-0 lg:pt-40"
	>
		<div class="flex flex-col items-center gap-14">
			<div class="flex flex-col items-start gap-8">
				<div class="w-full md:hidden">
					<img
						src="/images/Vertical-Jaga-Kualitas.webp"
						alt="Banner Alpha Propolis"
						width="720"
						height="420"
						loading="eager"
						decoding="async"
						fetchpriority="high"
						class="h-auto w-full"
					/>
				</div>

				<img
					src="/images/Horizontal-Jaga-Kualitas.webp"
					alt="Banner home Alpha Propolis"
					width="720"
					height="420"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class="hidden h-auto w-full md:block"
				/>

				<div class="flex w-full max-w-md flex-col items-start gap-4">
					<a href={ctaHref} class="block w-full">
						<img
							src="/images/btn-cegah-komplikasi-sekarang.webp"
							alt="Cegah Komplikasi Sekarang"
							width="720"
							height="160"
							loading="eager"
							decoding="async"
							class="h-auto w-full"
						/>
					</a>
				</div>
			</div>

			<figure class="hidden overflow-hidden md:block">
				<img
					src="/images/Foto%20Artis.webp"
					alt="Foto artis bersama Alpha Propolis"
					width="480"
					height="592"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class="h-full w-full object-cover"
				/>
			</figure>
		</div>
	</div>
</section>
