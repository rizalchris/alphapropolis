---
import { MessageCircle, ArrowRight } from "lucide-astro";
import Button from "../../ui/Button.astro";
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
const testimonialImages = [
	{
		src: "/images/Testimoni%20WA-01.webp",
		alt: "Testimoni pelanggan 1",
		width: 572,
		height: 382,
	},
	{
		src: "/images/Testimoni%20WA-02%201.webp",
		alt: "Testimoni pelanggan 2",
		width: 572,
		height: 400,
	},
	{
		src: "/images/Testimoni%20WA-03%201.webp",
		alt: "Testimoni pelanggan 3",
		width: 572,
		height: 382,
	},
	{
		src: "/images/Testimoni%20WA-04%201.webp",
		alt: "Testimoni pelanggan 4",
		width: 572,
		height: 382,
	},
	{
		src: "/images/Testimoni%20WA-05.webp",
		alt: "Testimoni pelanggan 5",
		width: 572,
		height: 382,
	},
];
---

<section
	id="testimonials-wa"
	aria-labelledby="proof-title"
	class="flex w-full flex-col items-center gap-8 bg-slate-900 px-6 py-16 text-white sm:px-8 sm:pt-24 lg:px-10"
>
	<h2 id="proof-title" class="max-w-[733px] text-center font-bold text-white">
		Lebih dari 100 Ribu Orang Telah Merasakan Manfaatnya
	</h2>
	<div
		class="w-full overflow-hidden"
		role="region"
		aria-label="Slider testimoni WhatsApp"
		data-testimonials-wa-slider
	>
		<ul
			class="flex w-full gap-4 overflow-x-hidden scroll-smooth"
			data-testimonials-wa-track
		>
			{
				testimonialImages.map((image) => (
					<li class="w-full shrink-0 basis-[82vw] max-w-[572px] overflow-hidden sm:basis-[calc(50%-0.5rem)] sm:max-w-none lg:basis-[calc(33.333%-0.75rem)]">
						<img
							src={image.src}
							alt={image.alt}
							width={image.width}
							height={image.height}
							loading="lazy"
							decoding="async"
							class="h-auto w-full rounded-none object-contain"
						/>
					</li>
				))
			}
		</ul>
	</div>
	<Button
		href={whatsappHref}
		size="lg"
		target="_blank"
		rel="noopener noreferrer"
	>
		<MessageCircle class="h-4 w-4" aria-hidden="true" />
		<span>Buktikan Sendiri</span>
		<ArrowRight class="h-4 w-4" aria-hidden="true" />
	</Button>
</section>

<script is:inline>
	(() => {
		const section = document.getElementById("testimonials-wa");
		const slider = section?.querySelector("[data-testimonials-wa-slider]");
		const track = section?.querySelector("[data-testimonials-wa-track]");

		if (!(slider instanceof HTMLElement) || !(track instanceof HTMLElement)) {
			return;
		}

		const slides = Array.from(track.children).filter(
			(child) => child instanceof HTMLElement,
		);

		if (!slides.length) {
			return;
		}

		const totalSlides = slides.length;
		slides
			.slice()
			.reverse()
			.forEach((slide) => {
				const clone = slide.cloneNode(true);
				if (clone instanceof HTMLElement) {
					clone.setAttribute("aria-hidden", "true");
					track.prepend(clone);
				}
			});
		slides.forEach((slide) => {
			const clone = slide.cloneNode(true);
			if (clone instanceof HTMLElement) {
				clone.setAttribute("aria-hidden", "true");
				track.append(clone);
			}
		});

		let activeIndex = totalSlides;
		let intervalId;
		let resetTimeoutId;

		const getRenderedSlides = () =>
			Array.from(track.children).filter(
				(child) => child instanceof HTMLElement,
			);

		const scrollToSlide = (nextIndex, behavior = "smooth") => {
			const renderedSlides = getRenderedSlides();
			const slide = renderedSlides[nextIndex];
			if (!(slide instanceof HTMLElement)) {
				return;
			}

			const centeredLeft =
				slide.offsetLeft - (track.clientWidth - slide.clientWidth) / 2;

			track.scrollTo({
				left: Math.max(0, centeredLeft),
				behavior,
			});
		};

		const clearResetTimeout = () => {
			if (resetTimeoutId) {
				window.clearTimeout(resetTimeoutId);
			}
		};

		const resetToStart = () => {
			clearResetTimeout();
			resetTimeoutId = window.setTimeout(() => {
				activeIndex = totalSlides;
				scrollToSlide(activeIndex, "auto");
			}, 450);
		};

		const startAutoSlide = () => {
			stopAutoSlide();
			intervalId = window.setInterval(() => {
				if (activeIndex === totalSlides * 2 - 1) {
					activeIndex += 1;
					scrollToSlide(activeIndex);
					resetToStart();
					return;
				}

				activeIndex += 1;
				scrollToSlide(activeIndex);
			}, 2000);
		};

		const stopAutoSlide = () => {
			if (intervalId) {
				window.clearInterval(intervalId);
			}

			clearResetTimeout();
		};

		slider.addEventListener("mouseenter", stopAutoSlide);
		slider.addEventListener("mouseleave", startAutoSlide);

		window.addEventListener("resize", () => {
			if (activeIndex < totalSlides || activeIndex >= totalSlides * 2) {
				activeIndex = totalSlides;
				scrollToSlide(activeIndex, "auto");
				return;
			}

			scrollToSlide(activeIndex, "auto");
		});

		scrollToSlide(activeIndex, "auto");
		startAutoSlide();
	})();
</script>
