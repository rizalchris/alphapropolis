---
import { MessageCircle, ArrowRight } from "lucide-astro";
import Button from "../../ui/Button.astro";
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section
	id="testimonials-wa"
	aria-labelledby="proof-title"
	class="flex w-full flex-col items-center gap-8 bg-slate-900 px-6 py-16 text-white sm:px-8 sm:pt-24 lg:px-10"
>
	<h2 id="proof-title" class="max-w-[733px] text-center font-bold text-white">
		Lebih dari 100 Ribu Orang Telah Merasakan Manfaatnya
	</h2>
	<ul
		class="flex w-full snap-x snap-mandatory gap-4 overflow-x-auto pb-2 lg:grid lg:grid-cols-5 lg:overflow-visible"
	>
		<li
			class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none"
		>
			<img
				src="/images/Testimoni%20WA-01.webp"
				alt="Testimoni pelanggan 1"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-none object-cover"
			/>
		</li>
		<li
			class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none"
		>
			<img
				src="/images/Testimoni%20WA-02%201.webp"
				alt="Testimoni pelanggan 2"
				width="572"
				height="400"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-none object-cover"
			/>
		</li>
		<li
			class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none"
		>
			<img
				src="/images/Testimoni%20WA-03%201.webp"
				alt="Testimoni pelanggan 3"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-none object-cover"
			/>
		</li>
		<li
			class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none"
		>
			<img
				src="/images/Testimoni%20WA-04%201.webp"
				alt="Testimoni pelanggan 4"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-none object-cover"
			/>
		</li>
		<li
			class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none"
		>
			<img
				src="/images/Testimoni%20WA-05.webp"
				alt="Testimoni pelanggan 5"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-none object-cover"
			/>
		</li>
	</ul>
	<Button
		href={whatsappHref}
		size="lg"
		target="_blank"
		rel="noopener noreferrer"
	>
		<MessageCircle class="h-4 w-4" aria-hidden="true" />
		<span>Buktikan Sendiri</span>
		<ArrowRight class="h-4 w-4" aria-hidden="true" />
	</Button>
</section>
