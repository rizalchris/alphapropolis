---
import SectionLabel from "../../shared/SectionLabel.astro";

const wetWoundImages = [
	"/images/luka-basah-1.webp",
	"/images/luka-basah-2.webp",
	"/images/luka-basah-3.webp",
	"/images/luka-basah-4.webp",
	"/images/luka-basah-5.webp",
];
---

<section
	id="medical-warning"
	aria-labelledby="medical-warning-title"
	class="landing-section bg-slate-900 px-6 pt-16 pb-16 text-white sm:px-8 sm:pb-24 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-8"
	>
		<div class="flex max-w-[933px] flex-col items-center gap-5 text-center">
			<SectionLabel text="Peringatan Medis" tone="red" />
			<h2 id="medical-warning-title" class="text-white">
				Banyak Penderita Diabetes Baru Menyadari Risiko Komplikasi
				Setelah Terjadi
			</h2>
		</div>

		<picture class="flex w-full justify-center">
			<img
				src="/images/anatomi.webp"
				alt="Resiko Diabetes"
				width="500"
				height="494"
				loading="lazy"
				decoding="async"
				class="h-auto rounded-none object-cover"
			/>
		</picture>

		<img
			src="/images/resiko.webp"
			alt="Risiko komplikasi diabetes"
			width="1440"
			height="900"
			loading="lazy"
			decoding="async"
			class="hidden w-full lg:block"
		/>

		<img
			src="/images/akibat-diabetes.webp"
			alt="Akibat diabetes"
			width="430"
			height="932"
			loading="lazy"
			decoding="async"
			class="block w-full lg:hidden"
		/>
	</div>

	<div class="mx-auto mt-10 hidden w-full max-w-[var(--container-xl)] lg:block">
		<div
			class="overflow-hidden"
			role="region"
			aria-label="Slider gambar luka basah"
			data-wet-wound-slider
		>
			<div
				class="flex gap-4 overflow-x-hidden scroll-smooth"
				data-wet-wound-track
			>
			{
				wetWoundImages.map((image, index) => (
					<div class="aspect-video w-full shrink-0 basis-full overflow-hidden lg:basis-[calc((100%-3rem)/4)]">
						<img
							src={image}
							alt={`Luka basah ${index + 1}`}
							width="480"
							height="480"
							loading="lazy"
							decoding="async"
							class="block h-full w-full object-cover"
						/>
					</div>
				))
			}
			</div>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		const section = document.getElementById("medical-warning");
		const slider = section?.querySelector("[data-wet-wound-slider]");
		const track = section?.querySelector("[data-wet-wound-track]");

		if (!(slider instanceof HTMLElement) || !(track instanceof HTMLElement)) {
			return;
		}

		const slides = Array.from(track.children).filter(
			(child) => child instanceof HTMLElement,
		);

		if (!slides.length) {
			return;
		}

		const totalSlides = slides.length;
		slides.forEach((slide) => {
			const clone = slide.cloneNode(true);
			if (clone instanceof HTMLElement) {
				clone.setAttribute("aria-hidden", "true");
				track.append(clone);
			}
		});

		let activeIndex = 0;
		let intervalId;
		let resetTimeoutId;

		const getRenderedSlides = () =>
			Array.from(track.children).filter(
				(child) => child instanceof HTMLElement,
			);

		const scrollToSlide = (nextIndex, behavior = "smooth") => {
			const renderedSlides = getRenderedSlides();
			const slide = renderedSlides[nextIndex];
			if (!(slide instanceof HTMLElement)) {
				return;
			}

			track.scrollTo({
				left: slide.offsetLeft,
				behavior,
			});
		};

		const clearResetTimeout = () => {
			if (resetTimeoutId) {
				window.clearTimeout(resetTimeoutId);
			}
		};

		const resetToStart = () => {
			clearResetTimeout();
			resetTimeoutId = window.setTimeout(() => {
				activeIndex = 0;
				scrollToSlide(0, "auto");
			}, 450);
		};

		const startAutoSlide = () => {
			stopAutoSlide();
			intervalId = window.setInterval(() => {
				if (activeIndex === totalSlides - 1) {
					activeIndex += 1;
					scrollToSlide(activeIndex);
					resetToStart();
					return;
				}

				activeIndex += 1;
				scrollToSlide(activeIndex);
			}, 2000);
		};

		const stopAutoSlide = () => {
			if (intervalId) {
				window.clearInterval(intervalId);
			}

			clearResetTimeout();
		};

		slider.addEventListener("mouseenter", stopAutoSlide);
		slider.addEventListener("mouseleave", startAutoSlide);

		window.addEventListener("resize", () => {
			if (activeIndex >= totalSlides) {
				activeIndex = 0;
				scrollToSlide(0, "auto");
				return;
			}

			scrollToSlide(activeIndex, "auto");
		});

		scrollToSlide(activeIndex, "auto");
		startAutoSlide();
	})();
</script>
