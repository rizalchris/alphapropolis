---
---

<section
	id="medical-warning"
	aria-label="Peringatan Medis"
	class="landing-section px-6 pt-16 pb-16 text-white sm:px-8 sm:pb-24 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-8"
	>
		<div class="flex max-w-[933px] flex-col items-center gap-5 text-center">
			<img
				src="/images/peringatan-medis.webp"
				alt="Peringatan Medis"
				width="933"
				height="180"
				loading="lazy"
				decoding="async"
				class="h-auto w-full"
			/>
		</div>

		<picture class="flex w-full justify-center">
			<img
				src="/images/anatomi.webp"
				alt="Resiko Diabetes"
				width="500"
				height="494"
				loading="lazy"
				decoding="async"
				class="h-auto rounded-none object-cover"
			/>
		</picture>

		<picture class="block w-full">
			<source media="(min-width: 1024px)" srcset="/images/Foto-Akibat.webp" />
			<img
				src="/images/akibat-diabetes.webp"
				alt="Akibat diabetes"
				width="430"
				height="932"
				loading="lazy"
				decoding="async"
				class="aspect-[215/466] h-auto w-full object-contain lg:aspect-[8/5]"
			/>
		</picture>
	</div>
</section>
