---
import {
	ArrowRight,
	MessageCircle,
} from "lucide-astro";
import Button from "../../ui/Button.astro";
import SectionLabel from "../../shared/SectionLabel.astro";
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section
	id="medical-warning"
	aria-labelledby="medical-warning-title"
	class="landing-section bg-slate-900 px-6 pt-24 text-white sm:px-8 sm:pb-24 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-16"
	>
		<div class="flex max-w-[933px] flex-col items-center gap-5 text-center">
			<SectionLabel text="Peringatan Medis" tone="red" />
			<h2 id="medical-warning-title" class="text-white">
				Banyak Penderita Diabetes Baru Menyadari Risiko Komplikasi
				Setelah Terjadi
			</h2>
		</div>

		<picture class="block w-full">
			<source
				media="(max-width: 640px)"
				srcset="/images/Resiko%20Diabetes%20mobile.webp"
			/>
			<img
				src="/images/Resiko-Diabetes.webp"
				alt="Resiko Diabetes"
				width="1269"
				height="494"
				loading="lazy"
				decoding="async"
				class="h-auto w-full rounded-[10px] object-cover"
			/>
		</picture>
	</div>
</section>

<section
	aria-labelledby="proof-title"
	class="flex w-full flex-col items-center gap-8 bg-slate-900 px-6 pb-24 text-white sm:px-8 sm:pt-24 lg:px-10"
>
	<h2
		id="proof-title"
		class="max-w-[733px] text-center font-bold leading-[57.6px] text-white"
	>
		Lebih dari 100 Ribu Orang Telah Merasakan Manfaatnya
	</h2>
	<ul class="flex w-full snap-x snap-mandatory gap-4 overflow-x-auto pb-2 lg:grid lg:grid-cols-5 lg:overflow-visible">
		<li class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none">
			<img
				src="/images/Testimoni%20WA-01.webp"
				alt="Testimoni pelanggan 1"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-[10px] object-cover"
			/>
		</li>
		<li class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none">
			<img
				src="/images/Testimoni%20WA-02%201.webp"
				alt="Testimoni pelanggan 2"
				width="572"
				height="400"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-[10px] object-cover"
			/>
		</li>
		<li class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none">
			<img
				src="/images/Testimoni%20WA-03%201.webp"
				alt="Testimoni pelanggan 3"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-[10px] object-cover"
			/>
		</li>
		<li class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none">
			<img
				src="/images/Testimoni%20WA-04%201.webp"
				alt="Testimoni pelanggan 4"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-[10px] object-cover"
			/>
		</li>
		<li class="w-[82vw] max-w-[572px] shrink-0 snap-start lg:w-full lg:max-w-none">
			<img
				src="/images/Testimoni%20WA-05.webp"
				alt="Testimoni pelanggan 5"
				width="572"
				height="382"
				loading="lazy"
				decoding="async"
				class="h-full w-full rounded-[10px] object-cover"
			/>
		</li>
	</ul>
	<Button
		href={whatsappHref}
		size="lg"
		target="_blank"
		rel="noopener noreferrer"
	>
		<MessageCircle class="h-4 w-4" aria-hidden="true" />
		<span>Buktikan Sendiri</span>
		<ArrowRight class="h-4 w-4" aria-hidden="true" />
	</Button>
</section>
