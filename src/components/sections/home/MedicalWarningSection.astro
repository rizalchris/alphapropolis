---
import SectionLabel from "../../shared/SectionLabel.astro";

const wetWoundImages = [
	"/images/luka-basah-1.webp",
	"/images/luka-basah-2.webp",
	"/images/luka-basah-3.webp",
	"/images/luka-basah-4.webp",
	"/images/luka-basah-5.webp",
];

const complicationCards = [
	{
		image: "/images/Jantung-dan-Otak.webp",
		title: "Jantung dan Otak",
		descriptionPrefix: "Sumbatan darah bisa berujung  ",
		descriptionHighlight: "STROKE atau SERANGAN JANTUNG.",
	},
	{
		image: "/images/Kaki-Kebas-Luka-Tak-Terasa-2.webp",
		title: "Kaki Kebas & Luka Tak Terasa",
		descriptionPrefix: "Infeksi bisa berujung ",
		descriptionHighlight: "AMPUTASI.",
	},
	{
		image: "/images/Mata.webp",
		title: "Mata",
		descriptionPrefix: "Retina bisa rusak perlahan dan berakhir",
		descriptionHighlight: "KEBUTAAN PERMANEN!",
	},
	{
		image: "/images/Ginjal.webp",
		title: "Ginjal",
		descriptionPrefix: "Ginjal bisa kehilangan fungsi hingga berisiko",
		descriptionHighlight: "CUCI DARAH SEUMUR HIDUP.",
	},
];
---

<section
	id="medical-warning"
	aria-labelledby="medical-warning-title"
	class="landing-section bg-slate-900 px-6 pt-16 pb-16 text-white sm:px-8 sm:pb-24 lg:px-10"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-8"
	>
		<div class="flex max-w-[933px] flex-col items-center gap-5 text-center">
			<SectionLabel text="Peringatan Medis" tone="red" />
			<h2 id="medical-warning-title" class="text-white">
				Banyak Penderita Diabetes Baru Menyadari Risiko Komplikasi
				Setelah Terjadi
			</h2>
		</div>

		<picture class="flex w-full justify-center">
			<img
				src="/images/anatomi.webp"
				alt="Resiko Diabetes"
				width="500"
				height="494"
				loading="lazy"
				decoding="async"
				class="h-auto rounded-none object-cover"
			/>
		</picture>

		<div
			class="grid w-full grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4"
		>
			{
				complicationCards.map((card) => (
					<article class="flex h-full flex-col overflow-hidden border border-white/10 bg-white text-stone-900 shadow-card">
						<img
							src={card.image}
							alt={card.title}
							width="480"
							height="320"
							loading="lazy"
							decoding="async"
							class="h-56 w-full object-cover"
						/>
						<div class="flex flex-1 flex-col gap-3 p-6">
							<h3 class="text-2xl leading-7 text-red-700">
								{card.title}
							</h3>
							<p class="text-lg leading-7 text-stone-900">
								{card.descriptionPrefix}
								<strong>{card.descriptionHighlight}</strong>
							</p>
						</div>
					</article>
				))
			}
		</div>
	</div>

	<div class="mt-10 w-full">
		<div
			class="grid w-full grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5"
		>
			{
				wetWoundImages.map((image, index) => (
					<img
						src={image}
						alt={`Luka basah ${index + 1}`}
						width="480"
						height="480"
						loading="lazy"
						decoding="async"
						class="h-full w-full object-cover"
					/>
				))
			}
		</div>
	</div>
</section>
