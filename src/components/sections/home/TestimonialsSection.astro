---
import { ArrowRight, MessageCircle } from "lucide-astro";
import Button from "../../ui/Button.astro";
import SectionLabel from "../../shared/SectionLabel.astro";
import { whatsappOrderUrl } from "../../../lib/site";

const whatsappHref = whatsappOrderUrl;

const stories = [
	{
		src: "/images/Testimoni-42.webp",
		alt: "Kisah transformasi pengguna Alpha Propolis 42",
	},
	{
		src: "/images/Testimoni-43.webp",
		alt: "Kisah transformasi pengguna Alpha Propolis 43",
	},
	{
		src: "/images/Testimoni-44.webp",
		alt: "Kisah transformasi pengguna Alpha Propolis 44",
	},
	{
		src: "/images/Testimoni-45.webp",
		alt: "Kisah transformasi pengguna Alpha Propolis 45",
	},
	{
		src: "/images/Testimoni-46.webp",
		alt: "Kisah transformasi pengguna Alpha Propolis 46",
	},
];
---

<section
	id="testimonials"
	aria-labelledby="testimonials-title"
	class="landing-section overflow-hidden bg-white py-16"
>
	<div class="flex flex-col items-center gap-5">
		<div
			class="flex max-w-[1344px] flex-col items-center gap-5 px-6 text-center sm:px-8 lg:px-10"
		>
			<SectionLabel text="Bukti Nyata" />
			<h2 id="testimonials-title" class="text-gray-900">
				Ini Kata Dokter dan Kata Mereka yang Sudah Membuktikan
			</h2>
		</div>

		<ul
			class="flex w-full gap-5 overflow-x-auto px-6 py-5 sm:px-8 lg:px-10"
		>
			{
				stories.map((story) => (
				<li class="shrink-0">
					<div class="flex w-[572px] max-w-[82vw] items-center justify-center overflow-hidden rounded-[10px]">
							<img
								src={story.src}
								alt={story.alt}
								width="572"
								height="382"
								loading="lazy"
								decoding="async"
								class="h-full w-full object-contain"
							/>
						</div>
					</li>
				))
			}
		</ul>

		<Button
			href={whatsappHref}
			size="lg"
			class="max-w-[90%]"
			target="_blank"
			rel="noopener noreferrer"
		>
			<MessageCircle class="h-4 w-4" aria-hidden="true" />
			<span>Lihat Bukti Lainnya</span>
			<ArrowRight class="h-4 w-4" aria-hidden="true" />
		</Button>
	</div>
</section>
