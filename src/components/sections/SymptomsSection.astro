---
const symptoms = [
	{
		icon: "💧",
		title: "Sering Buang Air Kecil",
		label: "Poliuria",
		iconBg: "bg-[var(--color-primary-soft-2)]",
	},
	{
		icon: "🥤",
		title: "Mudah Haus Berlebih",
		label: "Polidipsia",
		iconBg: "bg-[var(--color-danger-soft)]",
	},
	{
		icon: "🩹",
		title: "Luka Sulit Sembuh",
		label: "Penyembuhan Lambat",
		iconBg: "bg-[var(--color-violet-soft)]",
	},
	{
		icon: "👁️",
		title: "Penglihatan Kabur",
		label: "Retinopati Awal",
		iconBg: "bg-[var(--color-info-soft)]",
	},
	{
		icon: "🦶",
		title: "Kaki Kesemutan",
		label: "Neuropati Perifer",
		iconBg: "bg-[var(--color-success-soft)]",
	},
];
---

<section
	id="symptoms"
	aria-labelledby="symptoms-title"
	class="landing-section bg-[var(--color-surface)] px-6 py-20 sm:px-8 lg:px-10"
>
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-12">
		<div class="max-w-3xl text-center">
			<div class="inline-flex items-center gap-2 rounded-full border border-[color:rgb(251_191_36_/_0.3)] bg-[var(--color-primary-soft)] px-4 py-1.5 text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary-dark)]">
				<span class="h-2.5 w-2.5 rounded-full border border-[var(--color-primary)]"></span>
				Apakah Ini Terjadi Pada Anda?
			</div>
			<h2 id="symptoms-title" class="mt-5 text-[var(--color-heading)]">
				Kenali Gejala Diabetes
				<span class="block text-[var(--color-primary-dark)]">Sebelum Terlambat</span>
			</h2>
			<p class="mt-4 text-[length:var(--font-size-body-lg)] text-[var(--color-muted)]">
				Jika Anda mengalami satu atau lebih gejala ini, tubuh Anda sedang
				membutuhkan bantuan.
			</p>
		</div>

		<div class="grid w-full gap-5 sm:grid-cols-2 xl:grid-cols-5">
			{
				symptoms.map((item) => (
					<article class="flex flex-col items-center rounded-3xl border border-[var(--color-border)] bg-[var(--color-white)] px-5 py-8 text-center shadow-card-md">
						<div class:list={["flex h-16 w-16 items-center justify-center rounded-[20px] text-2xl", item.iconBg]}>
							{item.icon}
						</div>
						<h3 class="mt-5 text-base font-bold text-[var(--color-heading)]">
							{item.title}
						</h3>
						<p class="mt-2 text-xs text-[var(--color-muted-light)]">{item.label}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
