---
import SectionLabel from "../shared/SectionLabel.astro";

const steps = [
	{ number: "01", title: "Air Putih Hangat 100ml", image: "/images/cara konsumsi 1.webp" },
	{ number: "02", title: "Alpha Propolis 6 tetes", image: "/images/cara konsumsi 2.webp" },
	{ number: "03", title: "Aduk sampai tercampur rata", image: "/images/cara konsumsi 3.webp" },
	{ number: "04", title: "Minum 3 Kali Sehari", image: "/images/cara konsumsi 4.webp" },
];
---

<section id="how-to-use" aria-labelledby="how-to-use-title" class="landing-section bg-stone-50 px-6 py-24 sm:px-8 lg:px-10">
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-5">
		<div class="flex flex-col items-center gap-5 text-center">
			<SectionLabel text="Cara Konsumsi" />
			<h2 id="how-to-use-title" class="text-gray-900">Praktis, Mudah dan Simple</h2>
		</div>

		<ol class="grid w-full gap-5 pt-8 lg:grid-cols-4">
			{
				steps.map((step) => (
					<li>
						<div class="flex h-full flex-col items-center gap-5 rounded-3xl border border-stone-200 bg-white px-6 py-9 text-center shadow-card-lg">
							<p class="text-2xl font-bold leading-7 text-neutral-800">{step.number}</p>
							<img src={step.image} alt={step.title} width="213" height="298" loading="lazy" decoding="async" class="h-72 w-52 rounded-[10px] object-cover" />
							<h3 class="text-2xl font-bold leading-7 text-neutral-800">{step.title}</h3>
						</div>
					</li>
				))
			}
		</ol>

		<p class="max-w-[899px] pt-5 text-center text-2xl leading-8 text-gray-900">
			<strong>Catatan:</strong> Jika sedang mengkonsumsi obat dokter, cukup berikan jeda selama 1 jam sebelum atau sesudah obat harian Anda.
		</p>
	</div>
</section>
