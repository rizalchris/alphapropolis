---
const steps = [
	{
		icon: "📦",
		number: "01",
		title: "Buka Kemasan",
		description: "Periksa segel produk. Pastikan masih utuh sebelum digunakan.",
	},
	{
		icon: "💧",
		number: "02",
		title: "Tuang 10-15 Tetes",
		description: "Gunakan pipet bawaan. Ukur dengan tepat sesuai kebutuhan.",
	},
	{
		icon: "🫖",
		number: "03",
		title: "Campur Air Hangat",
		description: "Larutkan dalam 100 ml air hangat atau madu untuk rasa lebih baik.",
	},
	{
		icon: "🌅",
		number: "04",
		title: "Konsumsi 2x Sehari",
		description: "Pagi sebelum sarapan dan malam sebelum tidur untuk hasil optimal.",
	},
];
---

<section
	id="how-to-use"
	aria-labelledby="how-to-use-title"
	class="landing-section bg-[var(--color-surface)] px-6 py-20 sm:px-8 lg:px-10"
>
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-12">
		<div class="max-w-3xl text-center">
			<div class="inline-flex items-center gap-2 rounded-full border border-[color:rgb(251_191_36_/_0.3)] bg-[var(--color-primary-soft)] px-4 py-1.5 text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary-dark)]">
				<span class="h-2.5 w-2.5 rounded-full border border-[var(--color-primary)]"></span>
				Cara Konsumsi
			</div>
			<h2 id="how-to-use-title" class="mt-5 text-[var(--color-heading)]">
				Semudah Ini. Dalam 4 Langkah.
			</h2>
		</div>

		<div class="grid w-full gap-5 lg:grid-cols-4">
			{
				steps.map((step) => (
					<article class="relative rounded-3xl border border-[var(--color-border)] bg-[var(--color-white)] px-6 py-8 text-center shadow-card-lg">
						<div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl border-2 border-[color:rgb(251_191_36_/_0.3)] bg-[linear-gradient(180deg,var(--color-primary-soft),var(--color-primary-soft-2))] text-3xl">
							{step.icon}
						</div>
						<p class="mt-5 text-xs font-extrabold tracking-[0.18em] text-[var(--color-primary-dark)]">
							{step.number}
						</p>
						<h3 class="mt-2 text-base font-bold text-[var(--color-heading)]">
							{step.title}
						</h3>
						<p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">
							{step.description}
						</p>
					</article>
				))
			}
		</div>
	</div>
</section>
