---
import { ArrowRight, MessageCircle } from "lucide-astro";
import SectionLabel from "../shared/SectionLabel.astro";
import CertificationChips from "../shared/CertificationChips.astro";
import Button from "../ui/Button.astro";
import { whatsappOrderUrl } from "../../lib/site";

const whatsappHref = whatsappOrderUrl;
---

<section
	id="hero"
	aria-labelledby="hero-title"
	class="landing-section relative overflow-hidden bg-[linear-gradient(60deg,#f5f5f4_0%,#ffedd5_50%,#f5f5f4_100%)]"
>
	<div
		class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col gap-14 px-6 pb-10 pt-32 sm:px-8 sm:pt-36 lg:px-10 lg:pb-16 lg:pt-40"
	>
		<div
			class="grid items-center gap-14 lg:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.85fr)]"
		>
			<div class="flex flex-col items-start gap-8">
				<SectionLabel text="Formula Premium Lebah Trigona" />

				<div class="space-y-5">
					<h1 id="hero-title">
						Jaga Kualitas Hidup<br class="hidden sm:block" /> Mulai dari
						Propolis Terbaik
					</h1>
					<p>
						<strong
							>Dengan kadar fenol 1.600 mg/L yang lebih kuat dari
							standar nasional (SNI).</strong
						>{" "}
						Formulanya bekerja menstabilkan fungsi pankreas dan mengunci
						gula darah di angka normal. Saatnya bebaskan diri dari risiko
						komplikasi dan kembali <strong
							>#JagaSenyumKeluarga.</strong
						>
					</p>
				</div>

				<CertificationChips />

				<div class="flex w-full max-w-md flex-col items-start gap-4">
					<Button
						href={whatsappHref}
						size="lg"
						class="h-16 w-full"
						target="_blank"
						rel="noopener noreferrer"
					>
						<MessageCircle class="h-4 w-4" aria-hidden="true" />
						<span>Cegah Komplikasi Sekarang</span>
						<ArrowRight class="h-4 w-4" aria-hidden="true" />
					</Button>
					<p class="text-base leading-5 text-zinc-800">
						Respons &lt; 5 menit · Konsultasi gratis · Pengiriman
						hari ini
					</p>
				</div>
			</div>

			<figure
				class="overflow-hidden rounded-3xl border border-orange-300"
			>
				<img
					src="/images/Alpha-Propolis.webp"
					alt="Botol produk Alpha Propolis"
					width="480"
					height="592"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class="h-full min-h-[420px] w-full object-cover"
				/>
			</figure>
		</div>
	</div>
</section>
