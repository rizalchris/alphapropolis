---
import Button from "../ui/Button.astro";

const whatsappHref = "https://wa.me/6281234567890";

const certifications = ["BPOM RI", "HALAL MUI", "GMP", "ISO 22000"];

const stats = [
	{ icon: "💛", value: "10.000+", label: "Keluarga Terbantu" },
	{ icon: "⭐", value: "4.9 / 5", label: "Kepuasan Pelanggan" },
	{ icon: "🛡️", value: "30 Hari", label: "Garansi Uang Kembali" },
];
---

<section
	id="hero"
	aria-labelledby="hero-title"
	class="landing-section relative overflow-hidden bg-[linear-gradient(145deg,var(--color-surface-alt),var(--color-primary-soft-2),var(--color-surface-alt))]"
>
	<div class="pointer-events-none absolute -top-24 right-[-8rem] h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle,rgba(251,191,36,0.18),transparent_65%)]"></div>
	<div class="pointer-events-none absolute bottom-[-8rem] left-[-6rem] h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(34,197,94,0.12),transparent_65%)]"></div>

	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col gap-12 px-6 py-10 sm:px-8 lg:px-10 lg:py-16">
		<header class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
			<div class="flex items-center gap-3.5">
				<div class="flex h-11 w-11 items-center justify-center rounded-3xl bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-dark)] text-sm font-extrabold text-white shadow-primary">
					AP
				</div>
				<div>
					<p class="text-lg font-extrabold text-[var(--color-heading)]">
						Alpha Propolis
					</p>
					<p class="text-xs text-[var(--color-muted)]">
						Premium Health · Est. 2019
					</p>
				</div>
			</div>

			<ul class="flex flex-wrap justify-start gap-2 lg:justify-end">
				{
					certifications.map((item) => (
						<li class="rounded-full border border-[var(--color-border)] bg-[var(--color-white)] px-3.5 py-1.5 text-xs font-bold text-[var(--color-heading)] shadow-card">
							{item}
						</li>
					))
				}
			</ul>
		</header>

		<div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]">
			<div class="flex flex-col items-start gap-8">
				<div class="inline-flex items-center gap-2 rounded-full border border-[color:rgb(251_191_36_/_0.3)] bg-[var(--color-primary-soft)] px-4 py-1.5 text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary-dark)]">
					<span class="h-2.5 w-2.5 rounded-full border border-[var(--color-primary)]"></span>
					Formula Premium Lebah Trigona
				</div>

				<div class="max-w-2xl space-y-5">
					<h1 id="hero-title" class="max-w-[12ch] text-[length:var(--font-size-display)] leading-[var(--line-height-tight)] text-[var(--color-heading)]">
						Saatnya Anda Kembali <span class="text-[var(--color-primary-dark)]">Sehat</span> &amp; Berdaya
					</h1>
					<p class="max-w-[36rem] text-[length:var(--font-size-body-lg)] text-[var(--color-muted)]">
						Rasakan transformasi kesehatan bersama Alpha Propolis. Formula
						1600 mg/L Phenol dari 67% Trigona + 33% Apis Mellifera untuk
						penderita diabetes yang ingin hidup penuh semangat.
					</p>
				</div>

				<div class="grid w-full gap-4 sm:grid-cols-3">
					{
						stats.map((stat) => (
							<div class="rounded-[20px] border border-[var(--color-border)] bg-[var(--color-white)] px-5 py-4 shadow-card">
								<p class="text-center text-xl">{stat.icon}</p>
								<p class="mt-1 text-center text-xl font-extrabold text-[var(--color-heading)]">
									{stat.value}
								</p>
								<p class="mt-1 text-center text-xs text-[var(--color-muted)]">
									{stat.label}
								</p>
							</div>
						))
					}
				</div>

				<div class="flex w-full max-w-md flex-col items-start gap-3">
					<Button
						href={whatsappHref}
						size="lg"
						class="h-16 w-full px-8 text-lg"
						target="_blank"
						rel="noopener noreferrer"
					>
						Chat via WhatsApp Sekarang
					</Button>
					<p class="text-xs text-[var(--color-muted-light)]">
						Respons &lt; 5 menit · Konsultasi gratis · Pengiriman hari ini
					</p>
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-[28rem]">
				<div class="absolute inset-x-8 top-10 h-[24rem] rounded-full bg-[radial-gradient(circle,rgba(251,191,36,0.26),transparent_70%)]"></div>
				<div class="relative overflow-hidden rounded-[2rem] border border-[color:rgb(251_191_36_/_0.35)] bg-[linear-gradient(180deg,var(--color-primary-soft),var(--color-primary-soft-2))] p-6 shadow-product">
					<div class="rounded-[1.5rem] bg-[var(--color-white)]/70 p-4 backdrop-blur">
						<div class="flex items-center justify-between">
							<div>
								<p class="text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-primary-dark)]">
									Alpha Propolis
								</p>
								<p class="text-sm text-[var(--color-muted)]">
									Formula premium untuk pendamping hidup sehat
								</p>
							</div>
							<div class="rounded-full bg-[var(--color-white)] px-3 py-1 text-xs font-bold text-[var(--color-heading)] shadow-card">
								30 ml
							</div>
						</div>
					</div>

					<div class="mt-6 flex min-h-[26rem] items-center justify-center rounded-[1.75rem] border border-[color:rgb(251_191_36_/_0.25)] bg-[linear-gradient(180deg,rgba(255,255,255,0.55),rgba(255,255,255,0.2))] p-6">
						<img
							src="https://placehold.co/320x420"
							alt="Botol produk Alpha Propolis"
							width="320"
							height="420"
							loading="eager"
							decoding="async"
							fetchpriority="high"
							class="h-auto w-full max-w-[18rem] rounded-[1.5rem] object-cover shadow-card-lg"
						/>
					</div>

					<div class="mt-6 grid gap-3 sm:grid-cols-2">
						<div class="rounded-2xl bg-[var(--color-white)]/75 px-4 py-3 shadow-card">
							<p class="text-xs font-bold uppercase tracking-[0.14em] text-[var(--color-primary-dark)]">
								Kandungan utama
							</p>
							<p class="mt-1 text-sm text-[var(--color-heading)]">
								1600 mg/L Phenol · Flavonoid tinggi
							</p>
						</div>
						<div class="rounded-2xl bg-[var(--color-white)]/75 px-4 py-3 shadow-card">
							<p class="text-xs font-bold uppercase tracking-[0.14em] text-[var(--color-primary-dark)]">
								Target pengguna
							</p>
							<p class="mt-1 text-sm text-[var(--color-heading)]">
								Penderita diabetes yang ingin lebih stabil dan aktif
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
