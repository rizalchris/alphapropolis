---
import { ArrowRight, Check, MessageCircle } from "lucide-astro";
import Button from "../ui/Button.astro";
import SectionLabel from "../shared/SectionLabel.astro";
import { whatsappOrderUrl } from "../../lib/site";

const whatsappHref = whatsappOrderUrl;

const benefits = [
	"Menjaga gula darah tetap terkontrol",
	"Melawan radikal bebas",
	"Meningkatkan kekebalan tubuh",
	"Merawat sensitivitas insulin",
	"Membantu menjaga energi harian",
	"Mendukung proses percepatan pemulihan luka",
	"Membantu mengatasi infeksi saluran pernapasan",
];

const doctors = [
	{
		name: "dr. Andi Kurniawan, Sp.PD",
		image: "/images/dr.%20Andi%20Kurniawan,%20Sp.PD.webp",
		quote:
			"Propolis membantu kontrol gula darah pada pasien Diabetes, karena propolis meningkatkan sensitivitas insulin sehingga lebih peka menarik darah dalam sel.",
	},
	{
		name: "Dr. Endang, M.Si",
		image: "/images/Dr.%20Endang,%20M.Si.webp",
		quote:
			"Propolis adalah kombinasi getah pohon dan lilin lebah yang kaya polifenol serta flavonoid. Manfaat alaminya bekerja sebagai antivirus, antibakteri, anti radang, sekaligus melindungi dan memperbaiki sistem saraf.",
	},
	{
		name: "Dr. Mahani, M.Si",
		image: "/images/Dr.%20Mahani,%20M.Si.webp",
		quote:
			"Dengan minum Propolis, konsentrasi gula pada darah akan berkurang, sehingga kesempatan gula dijadikan media tumbuh bagi jamur tidak terjadi, sehingga luka akan bisa sembuh.",
	},
];
---

<section id="doctors" aria-labelledby="doctors-title" class="landing-section bg-white px-6 py-24 sm:px-8 lg:px-10">
	<div class="mx-auto flex w-full max-w-[var(--container-xl)] flex-col items-center gap-10">
		<section class="flex w-full flex-col items-center gap-12 rounded-3xl border border-amber-400/30 bg-gradient-to-br from-orange-50 to-stone-50 px-6 py-11 sm:px-12" aria-labelledby="diabetes-comfort-title">
			<div class="flex max-w-4xl flex-col items-center gap-5 text-center">
				<h2 id="diabetes-comfort-title" class="text-4xl font-bold leading-8 text-gray-900">
					Cara Nyaman Berdamai dengan Diabetes
				</h2>
				<p class="text-stone-900">
					Mulai langkah praktis harian ini demi tubuh yang tetap aktif, bertenaga, dan selalu siap #JagaSenyumKeluarga.
				</p>
			</div>
			<ul class="grid w-full max-w-5xl gap-2.5 lg:grid-cols-2">
				{
					benefits.map((benefit) => (
						<li class="flex items-start gap-3 text-xl leading-6 text-stone-900">
							<span class="mt-px flex h-6 w-6 shrink-0 items-center justify-center rounded-xl bg-green-100">
								<Check class="h-3 w-3 text-green-500" aria-hidden="true" />
							</span>
							<span>{benefit}</span>
						</li>
					))
				}
			</ul>
		</section>

		<section class="flex w-full flex-col items-center gap-10" aria-labelledby="doctors-title">
			<div class="flex flex-col items-center gap-5 text-center">
				<SectionLabel text="Validasi Ahli Kesehatan" />
				<h2 id="doctors-title" class="max-w-[651px] text-gray-900">
					Beralih ke Propolis Terbaik Pilihan Dokter untuk Anda
				</h2>
			</div>
			<ul class="grid w-full gap-5 lg:grid-cols-3">
				{
					doctors.map((doctor) => (
						<li class="h-full">
							<div class="flex h-full w-full flex-col gap-5 rounded-3xl bg-white p-5 shadow-[0px_8px_32px_0px_rgba(0,0,0,0.06)] outline outline-1 outline-offset-[-1px] outline-stone-200">
								<div class="flex items-center gap-4">
									<div class="flex size-16 shrink-0 items-center justify-center overflow-hidden rounded-[36px] bg-stone-100 p-1 outline outline-[3px] outline-offset-[-3px] outline-orange-50">
										<img
											src={doctor.image}
											alt={doctor.name}
											width="79"
											height="158"
											loading="lazy"
											decoding="async"
											class="h-full w-full object-contain"
										/>
									</div>
									<div class="w-full">
										<div class="text-2xl font-bold leading-8 text-gray-900">
											{doctor.name}
										</div>
									</div>
								</div>
								<div class="flex h-full flex-col justify-start rounded-2xl border-l-4 border-amber-400 bg-orange-50 px-6 py-5">
									<div class="text-base font-normal leading-6 text-stone-900">
										{doctor.quote}
									</div>
								</div>
							</div>
						</li>
					))
				}
			</ul>
			<Button href={whatsappHref} size="lg" target="_blank" rel="noopener noreferrer">
				<MessageCircle class="h-4 w-4" aria-hidden="true" />
				<span>Pilih Rekomendasi Dokter</span>
				<ArrowRight class="h-4 w-4" aria-hidden="true" />
			</Button>
		</section>
	</div>
</section>
