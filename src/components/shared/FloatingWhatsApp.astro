---
import { MessageCircle } from "lucide-astro";

const whatsappUrl = "https://wa.me/6281234567890";
---

<a href={whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="Chat via WhatsApp">
	<div class="fixed bottom-6 right-6 z-50 inline-flex items-center gap-2.5 rounded-full bg-[var(--color-whatsapp)] px-6 py-3.5 shadow-[0_12px_30px_rgba(37,211,102,0.28)] transition-transform duration-200 hover:-translate-y-0.5 hover:brightness-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-whatsapp)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-page)] sm:bottom-8 sm:right-8">
		<MessageCircle class="h-5 w-5 text-white" aria-hidden="true" />
		<div class="flex flex-col items-start">
			<div class="text-base font-bold leading-6 text-white">
				Chat via WhatsApp
			</div>
		</div>
	</div>
</a>
