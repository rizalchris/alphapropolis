---
import { MessageCircle } from "lucide-astro";
import { whatsappOrderUrl } from "../../lib/site";

const whatsappUrl = whatsappOrderUrl;
---

<a
	href={whatsappUrl}
	target="_blank"
	rel="noopener noreferrer"
	aria-label="Chat via WhatsApp"
	class="fixed bottom-6 right-6 z-50 inline-flex items-center gap-2.5 rounded-full bg-[var(--color-whatsapp)] px-5 py-3.5 shadow-[0_12px_30px_rgba(37,211,102,0.28)] transition-transform duration-200 hover:-translate-y-0.5 hover:brightness-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-whatsapp)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-page)] sm:bottom-8 sm:right-8"
>
		<MessageCircle class="h-5 w-5 text-white" aria-hidden="true" />
		<div class="flex flex-col items-start">
			<div class="text-[18px] font-bold leading-6 text-white sm:text-base">
				Chat via WhatsApp
			</div>
		</div>
</a>
