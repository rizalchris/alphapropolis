---
import { Check } from "lucide-astro";

const {
	items = ["BPOM TR-213656281", "HALAL MUI", "CPOTB", "ISO 9001:2015"],
	class: className = "",
} = Astro.props as {
	items?: string[];
	class?: string;
};
---

<ul class:list={["flex flex-wrap items-center gap-1.5", className]}>
	{
		items.map((item) => (
			<li class="inline-flex items-center gap-1 rounded-full border border-amber-400 bg-amber-100 px-3.5 py-[5px] text-xs font-bold leading-4 text-stone-900 shadow-[0_1px_6px_rgba(0,0,0,0.06)]">
				<Check class="h-3 w-3 text-amber-700" aria-hidden="true" />
				<span>{item}</span>
			</li>
		))
	}
</ul>
