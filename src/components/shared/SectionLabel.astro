---
import { Sparkles } from "lucide-astro";

const { text, tone = "amber" } = Astro.props as {
	text: string;
	tone?: "amber" | "red";
};

const classes =
	tone === "red"
		? "border-red-600/30 bg-red-600/20 text-red-500"
		: "border-amber-400/30 bg-orange-50 text-amber-400";
---

<p class:list={[
	"inline-flex items-center gap-1.5 rounded-none border px-4 py-1.5 text-xs font-bold uppercase leading-4 tracking-[0.16em]",
	classes,
]}>
	<Sparkles class="h-3 w-3" aria-hidden="true" />
	<span>{text}</span>
</p>
