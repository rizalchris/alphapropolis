---
type Variant = "primary" | "secondary" | "ghost";
type Size = "sm" | "md" | "lg";

const {
	href,
	type = "button",
	variant = "primary",
	size = "md",
	class: className = "",
	...rest
} = Astro.props as {
	href?: string;
	type?: "button" | "submit" | "reset";
	variant?: Variant;
	size?: Size;
	class?: string;
};

const base =
	"inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-page)] disabled:pointer-events-none disabled:opacity-50";

const variants: Record<Variant, string> = {
	primary:
		"bg-[linear-gradient(135deg,var(--color-whatsapp),var(--color-whatsapp-dark))] text-[var(--color-white)] shadow-whatsapp hover:-translate-y-0.5 hover:brightness-105",
	secondary:
		"border border-[var(--color-border)] bg-[var(--color-white)] text-[var(--color-heading)] hover:border-[var(--color-primary)]/50 hover:bg-[var(--color-primary-soft)]",
	ghost:
		"bg-transparent text-[var(--color-body)] hover:bg-[var(--color-primary-soft)] hover:text-[var(--color-heading)]",
};

const sizes: Record<Size, string> = {
	sm: "px-5 py-1.5 text-[13px]",
	md: "px-5 py-2 text-[13px]",
	lg: "px-5 py-5 text-[13px] sm:px-12 sm:text-lg leading-7",
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`.trim();
---

{
	href ? (
		<a href={href} class={classes} {...rest}>
			<slot />
		</a>
	) : (
		<button type={type} class={classes} {...rest}>
			<slot />
		</button>
	)
}
