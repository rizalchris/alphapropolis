---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layouts/Header.astro";
import HeroSection from "../components/sections/home/HeroSection.astro";
import SymptomsSection from "../components/sections/home/SymptomsSection.astro";
import MedicalWarningSection from "../components/sections/home/MedicalWarningSection.astro";
import WhyAlphaSection from "../components/sections/home/WhyAlphaSection.astro";
import DoctorsSection from "../components/sections/home/DoctorsSection.astro";
import HowToUseSection from "../components/sections/home/HowToUseSection.astro";
import CertificationSection from "../components/sections/home/CertificationSection.astro";
import RiskJourneySection from "../components/sections/home/RiskJourneySection.astro";
import TestimonialsSection from "../components/sections/home/TestimonialsSection.astro";
import PricingSection from "../components/sections/home/PricingSection.astro";
import FaqSection from "../components/sections/home/FaqSection.astro";
import FinalCtaSection from "../components/sections/home/FinalCtaSection.astro";
import FooterSection from "../components/sections/home/FooterSection.astro";
import FloatingWhatsApp from "../components/shared/FloatingWhatsApp.astro";
import { whatsappOrderUrl } from "../lib/site";

const title = "Alpha Propolis | Solusi Pendamping Diabetes";
const description =
	"Alpha Propolis membantu menjaga kualitas hidup dengan formula premium lebah Trigona, sertifikasi resmi, panduan konsumsi, dan penawaran paket hemat.";
const image = "/images/Alpha-Propolis.webp";
const keywords =
	"Alpha Propolis, propolis diabetes, propolis Trigona, suplemen kesehatan, propolis halal, propolis BPOM";
const siteUrl = "https://alphapropolis.id/";
const productImageUrl = "https://alphapropolis.id/images/Alpha-Propolis.webp";

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": "https://alphapropolis.id/#organization",
			name: "Alpha Propolis",
			legalName: "PT. Unimax Power",
			url: siteUrl,
			logo: "https://alphapropolis.id/images/logo.webp",
			image: productImageUrl,
			email: "info@alphapropolis.id",
			telephone: "+628118131000",
			address: {
				"@type": "PostalAddress",
				streetAddress: "Jl. Gading Bukit Indah, Blok L 17, Kelapa Gading",
				addressLocality: "Jakarta Utara",
				addressRegion: "DKI Jakarta",
				addressCountry: "ID",
			},
			contactPoint: {
				"@type": "ContactPoint",
				telephone: "+628118131000",
				contactType: "customer service",
				availableLanguage: ["id"],
				url: whatsappOrderUrl,
			},
		},
		{
			"@type": "WebSite",
			"@id": "https://alphapropolis.id/#website",
			name: "Alpha Propolis",
			url: siteUrl,
			publisher: {
				"@id": "https://alphapropolis.id/#organization",
			},
		},
		{
			"@type": "WebPage",
			"@id": "https://alphapropolis.id/#webpage",
			url: siteUrl,
			name: title,
			description,
			isPartOf: {
				"@id": "https://alphapropolis.id/#website",
			},
			about: {
				"@id": "https://alphapropolis.id/#product",
			},
			primaryImageOfPage: {
				"@type": "ImageObject",
				url: productImageUrl,
				width: 480,
				height: 592,
			},
			breadcrumb: {
				"@id": "https://alphapropolis.id/#breadcrumb",
			},
			inLanguage: "id-ID",
		},
		{
			"@type": "BreadcrumbList",
			"@id": "https://alphapropolis.id/#breadcrumb",
			itemListElement: [
				{
					"@type": "ListItem",
					position: 1,
					name: "Beranda",
					item: siteUrl,
				},
			],
		},
		{
			"@type": "Product",
			"@id": "https://alphapropolis.id/#product",
			name: "Alpha Propolis",
			sku: "ALPHA-PROPOLIS",
			description:
				"Suplemen kesehatan premium dari lebah Trigona dan Apis Mellifera untuk pendamping rutinitas sehat.",
			image: productImageUrl,
			brand: {
				"@id": "https://alphapropolis.id/#organization",
			},
			category: "HealthSupplement",
			offers: [
				{
					"@type": "Offer",
					name: "Paket A",
					price: "185000",
					priceCurrency: "IDR",
					availability: "https://schema.org/InStock",
					itemCondition: "https://schema.org/NewCondition",
					url: "https://alphapropolis.id/#pricing",
					seller: {
						"@id": "https://alphapropolis.id/#organization",
					},
				},
				{
					"@type": "Offer",
					name: "Paket Spesial Bundling",
					price: "370000",
					priceCurrency: "IDR",
					availability: "https://schema.org/InStock",
					itemCondition: "https://schema.org/NewCondition",
					url: "https://alphapropolis.id/#pricing",
					seller: {
						"@id": "https://alphapropolis.id/#organization",
					},
				},
			],
		},
		{
			"@type": "HowTo",
			"@id": "https://alphapropolis.id/#how-to-use-schema",
			name: "Cara konsumsi Alpha Propolis",
			description:
				"Panduan konsumsi Alpha Propolis sesuai materi pada halaman produk.",
			image: "https://alphapropolis.id/images/cara%20konsumsi%204.webp",
			totalTime: "PT2M",
			supply: [
				{
					"@type": "HowToSupply",
					name: "Air putih hangat 100 ml",
				},
				{
					"@type": "HowToSupply",
					name: "Alpha Propolis 6 tetes",
				},
			],
			step: [
				{
					"@type": "HowToStep",
					position: 1,
					name: "Siapkan air putih hangat",
					text: "Siapkan air putih hangat sebanyak 100 ml.",
					image: "https://alphapropolis.id/images/cara%20konsumsi%201.webp",
				},
				{
					"@type": "HowToStep",
					position: 2,
					name: "Teteskan Alpha Propolis",
					text: "Tambahkan Alpha Propolis sebanyak 6 tetes.",
					image: "https://alphapropolis.id/images/cara%20konsumsi%202.webp",
				},
				{
					"@type": "HowToStep",
					position: 3,
					name: "Aduk sampai rata",
					text: "Aduk sampai tercampur rata.",
					image: "https://alphapropolis.id/images/cara%20konsumsi%203.webp",
				},
				{
					"@type": "HowToStep",
					position: 4,
					name: "Minum 3 kali sehari",
					text: "Minum 3 kali sehari. Jika sedang mengonsumsi obat dokter, beri jeda 1 jam sebelum atau sesudah obat harian.",
					image: "https://alphapropolis.id/images/cara%20konsumsi%204.webp",
				},
			],
		},
		{
			"@type": "FAQPage",
			"@id": "https://alphapropolis.id/#faq-schema",
			mainEntity: [
				{
					"@type": "Question",
					name: "Apakah Alpha Propolis aman dikonsumsi setiap hari dalam jangka panjang?",
					acceptedAnswer: {
						"@type": "Answer",
						text: "Gunakan sesuai aturan pakai. Jika Anda memiliki kondisi khusus, sedang hamil, menyusui, alergi produk lebah, atau menjalani pengobatan rutin, konsultasikan dengan dokter terlebih dahulu.",
					},
				},
				{
					"@type": "Question",
					name: "Berapa tetes dosis yang dianjurkan untuk membantu pemulihan tubuh?",
					acceptedAnswer: {
						"@type": "Answer",
						text: "Panduan pada halaman ini menggunakan 6 tetes dalam 100 ml air hangat, diminum 3 kali sehari. Sesuaikan dengan arahan tenaga kesehatan bila Anda sedang menjalani terapi tertentu.",
					},
				},
				{
					"@type": "Question",
					name: "Apakah produk ini bisa menggantikan fungsi obat diabetes utama atau suntik insulin?",
					acceptedAnswer: {
						"@type": "Answer",
						text: "Tidak. Alpha Propolis adalah suplemen pendamping dan bukan pengganti obat dokter, insulin, atau terapi medis utama.",
					},
				},
				{
					"@type": "Question",
					name: "Bagaimana cara Alpha Propolis membantu proses pemulihan penderita TBC atau gangguan paru-paru?",
					acceptedAnswer: {
						"@type": "Answer",
						text: "Kandungan propolis diposisikan sebagai pendamping untuk membantu daya tahan tubuh. Pengobatan TBC dengan OAT tetap wajib dilanjutkan sampai selesai sesuai instruksi dokter.",
					},
				},
				{
					"@type": "Question",
					name: "Apakah Alpha Propolis sudah bersertifikasi Halal?",
					acceptedAnswer: {
						"@type": "Answer",
						text: "Ya, materi halaman ini mencantumkan sertifikasi HALAL MUI ID00410000283380322.",
					},
				},
				{
					"@type": "Question",
					name: "Apakah bisa melakukan pembayaran di tempat (COD)?",
					acceptedAnswer: {
						"@type": "Answer",
						text: "Hubungi tim WhatsApp untuk memastikan ketersediaan COD berdasarkan wilayah pengiriman Anda.",
					},
				},
			],
		},
	],
};
---

<Layout
	title={title}
	description={description}
	image={image}
	keywords={keywords}
	structuredData={structuredData}
>
	<Header />

	<main id="main-content" class="landing-page">
		<article aria-labelledby="hero-title">
			<HeroSection />
			<SymptomsSection />
			<MedicalWarningSection />
			<WhyAlphaSection />
			<DoctorsSection />
			<TestimonialsSection />
			<HowToUseSection />
			<RiskJourneySection />
			<CertificationSection />
			<PricingSection />
			<FaqSection />
			<FinalCtaSection />
		</article>
	</main>

	<FooterSection />
	<FloatingWhatsApp />
</Layout>
