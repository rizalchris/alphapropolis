---
import "../styles/global.css";

const {
	title = "Alpha Propolis",
	description = "Landing page Alpha Propolis untuk membantu perjalanan hidup sehat penderita diabetes.",
	structuredData,
} = Astro.props;

const siteUrl = "https://alphapropolis.id";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const fontHref =
	"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap";
---

<!doctype html>
<html lang="id" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#111827" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="https://placehold.co" />
		<link
			rel="preload"
			as="style"
			href={fontHref}
		/>
		<link
			href={fontHref}
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link href={fontHref} rel="stylesheet" />
		</noscript>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta property="og:site_name" content="Alpha Propolis" />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="id_ID" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{
			structuredData && (
				<script
					type="application/ld+json"
					set:html={JSON.stringify(structuredData)}
				/>
			)
		}
	</head>
	<body>
		<slot />
	</body>
</html>
